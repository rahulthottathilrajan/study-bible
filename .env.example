# The Bible Scrollers — Environment Variables
# Copy to .env.local for local development.
# All variables must also be set in Vercel: Settings → Environment Variables

# ── Supabase ─────────────────────────────────────────────────
# Public — safe to expose in client bundles
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — NEVER expose in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ───────────────────────────────────────────────────
# Server-only
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (server-only)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_PRICE_LIFETIME=price_...

# ── App ───────────────────────────────────────────────────────
# Public — used in success/cancel redirect URLs
NEXT_PUBLIC_SITE_URL=https://study-bible-two.vercel.app
