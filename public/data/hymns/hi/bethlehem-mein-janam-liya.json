  "story": "A beloved Hindi Christmas bhajan that has been sung in churches and homes across North India for generations. This traditional nativity hymn celebrates the birth of Christ in Bethlehem with joyful simplicity. It is a highlight of Christmas Eve services and carol singing events throughout Hindi-speaking regions.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "बेथलहम में जन्म लिया",
          "दाऊद के नगर में आया",
          "उद्धारकर्ता जन्मा आज",
          "यीशु मसीह जन्मा आज"
        ],
        "linesRomanized": [
          "Bethlehem mein janam liyaa",
          "Daood ke nagar mein aayaa",
          "Uddhaarakartaa janmaa aaj",
          "Yeshu Maseeh janmaa aaj"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "स्वर्गदूतों ने गाया",
          "चरवाहे दौड़कर आए",
          "तारा दिखाता रहा राह",
          "ज्ञानियों ने भेंट चढ़ाई"
        ],
        "linesRomanized": [
          "Swargadooton ne gaayaa",
          "Charwaahe daudkar aaye",
          "Taaraa dikhaataa rahaa raah",
          "Gyaaniyon ne bhent chadhaaee"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "चरनी में जन्मा राजा",
          "गरीबी में आया प्रभु",
          "मनुष्यों को छुड़ाने को",
          "देव पुत्र धरती पर आया"
        ],
        "linesRomanized": [
          "Charni mein janmaa raajaa",
          "Gareebi mein aayaa Prabhu",
          "Manushyon ko chhudaane ko",
          "Dev putra dharti par aayaa"
        ]
      }
    ]
  },
