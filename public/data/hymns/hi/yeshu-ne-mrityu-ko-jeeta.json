      {
        "type": "chorus",
        "lines": [
          "यीशु ने मृत्यु को जीता",
          "कब्र पर विजय पाई",
          "हल्लेलूयाह हल्लेलूयाह",
          "जय जय यीशु की जय"
        ],
        "linesRomanized": [
          "Yeshu ne mrityu ko jeetaa",
          "Kabr par vijay paaee",
          "Halleluyaah halleluyaah",
          "Jay jay Yeshu ki jay"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "कब्र का पत्थर लुढ़काया",
          "मौत की शक्ति तोड़ दी",
          "तीसरे दिन जी उठा वो",
          "वायदा पूरा किया"
        ],
        "linesRomanized": [
          "Kabr kaa patthar ludhkaayaa",
          "Maut ki shakti tod dee",
          "Teesre din jee uthaa wo",
          "Wayadaa pooraa kiyaa"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "अब मृत्यु का डंक कहाँ",
          "अब कब्र की जीत कहाँ",
          "यीशु जीवित है सदा",
          "हम भी जीवित रहेंगे सदा"
        ],
        "linesRomanized": [
          "Ab mrityu kaa dank kahaan",
          "Ab kabr ki jeet kahaan",
          "Yeshu jeevit hai sadaa",
          "Ham bhi jeevit rahenge sadaa"
        ]
      }
    ]
