  "story": "A profound bhajan meditating on Christ's great 'I Am' declarations in the Gospel of John. This hymn invites believers into a deeper understanding of who Jesus is. It has been a cornerstone of Hindi Christian worship, sung with reverence and conviction.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "मार्ग सत्य और जीवन",
          "तू ही है यीशु",
          "तेरे बिना कोई",
          "पिता के पास नहीं आता"
        ],
        "linesRomanized": [
          "Maarg satya aur jeevan",
          "Tu hi hai Yeshu",
          "Tere binaa koi",
          "Pitaa ke paas nahin aataa"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "मैं अच्छा चरवाहा हूँ",
          "भेड़ों के लिए प्राण देता",
          "मैं पुनरुत्थान और जीवन हूँ",
          "विश्वास करने वाला जीएगा"
        ],
        "linesRomanized": [
          "Main achchhaa charwaahaa hoon",
          "Bhedon ke liye praan detaa",
          "Main punarutthan aur jeevan hoon",
          "Vishwaas karne waalaa jeeyegaa"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "मैं जगत की ज्योति हूँ",
          "मेरे पीछे चलने वाला",
          "अन्धकार में न चलेगा",
          "जीवन की ज्योति पाएगा"
        ],
        "linesRomanized": [
          "Main jagat ki jyoti hoon",
          "Mere peechchhe chalne waalaa",
          "Andhakaar mein na chalegaa",
          "Jeevan ki jyoti paayegaa"
        ]
      }
    ]
  },
