  "story": "An intimate devotional bhajan expressing the believer's love for Christ. This tender hymn captures the heart of Hindi Christian devotion — a soul overwhelmed by grace pouring out love in return. It is a favorite during evening prayer meetings and personal worship.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "प्रेम करता हूँ तुझसे यीशु",
          "तूने पहले प्रेम किया",
          "मेरा जीवन तेरे लिए",
          "मेरा सब कुछ तेरे लिए"
        ],
        "linesRomanized": [
          "Prem kartaa hoon tujhse Yeshu",
          "Toone pahle prem kiyaa",
          "Meraa jeevan tere liye",
          "Meraa sab kuchh tere liye"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "क्रूस पर तेरा प्रेम देखा",
          "मुझे भुलाकर तूने प्राण दिए",
          "उस प्रेम के बदले में",
          "मेरा दिल तेरे लिए"
        ],
        "linesRomanized": [
          "Kroos par teraa prem dekhaa",
          "Mujhe bhulaakar toone praan diye",
          "Us prem ke badle mein",
          "Meraa dil tere liye"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "दुनिया भर दे दे भले",
          "तेरे प्रेम की बराबरी नहीं",
          "प्रेम करता हूँ तुझसे",
          "सदा प्रेम करूँगा"
        ],
        "linesRomanized": [
          "Duniyaa bhar de de bhale",
          "Tere prem ki baraabaree nahin",
          "Prem kartaa hoon tujhse",
          "Sadaa prem karoongaa"
        ]
      }
    ]
  },
