  "story": "A bhajan of patient trust drawn from Isaiah 40, beloved in Hindi prayer meetings. This hymn encourages believers to find renewed strength through waiting on the Lord, promising that those who trust will soar like eagles above their trials.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "इन्तज़ार करूँगा प्रभु का",
          "बल नया करेगा वो",
          "उकाब की तरह उड़ूँगा",
          "थकूँगा नहीं गिरूँगा नहीं"
        ],
        "linesRomanized": [
          "Intezaar karoongaa Prabhu kaa",
          "Bal nayaa karegaa wo",
          "Ukaab ki tarah udoongaa",
          "Thakoongaa nahin giroongaa nahin"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "दौड़ूँगा और थकूँगा नहीं",
          "चलूँगा और गिरूँगा नहीं",
          "प्रभु की बाट जोहने वाले",
          "बल पाएँगे"
        ],
        "linesRomanized": [
          "Daudoongaa aur thakoongaa nahin",
          "Chaloongaa aur giroongaa nahin",
          "Prabhu ki baat johne waale",
          "Bal paayenge"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "जवान थकते हैं",
          "बालक ठोकर खाते हैं",
          "पर प्रभु पर भरोसा रखने वाले",
          "कभी नहीं गिरेंगे"
        ],
        "linesRomanized": [
          "Jawaan thakte hain",
          "Baalak thokar khaate hain",
          "Par Prabhu par bharosaa rakhne waale",
          "Kabhi nahin girenge"
        ]
      }
    ]
  },
