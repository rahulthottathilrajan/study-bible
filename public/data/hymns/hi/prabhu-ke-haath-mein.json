  "story": "A bhajan of deep assurance reminding believers they are held securely in God's hands. This traditional hymn draws from Isaiah's tender image of God engraving His children on His palms. It has brought immeasurable comfort during times of loss in Hindi-speaking Christian communities.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "प्रभु के हाथ में हूँ मैं",
          "सुरक्षित हूँ सदा",
          "कोई छीन नहीं सकता",
          "मुझे उसके हाथ से"
        ],
        "linesRomanized": [
          "Prabhu ke haath mein hoon main",
          "Surakshit hoon sadaa",
          "Koi chheen nahin saktaa",
          "Mujhe uske haath se"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "हथेली पर खोद रखा है",
          "मेरा नाम उसने",
          "भूलेगा नहीं कभी भी",
          "मुझसे प्रेम करता है वो"
        ],
        "linesRomanized": [
          "Hatheli par khod rakhaa hai",
          "Meraa naam usne",
          "Bhoolegaa nahin kabhi bhi",
          "Mujhse prem kartaa hai wo"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "तूफ़ान आए चाहे",
          "बाढ़ आए चाहे",
          "प्रभु का हाथ मुझे थामेगा",
          "मैं नहीं डरूँगा"
        ],
        "linesRomanized": [
          "Toofaan aaye chaahe",
          "Baadh aaye chaahe",
          "Prabhu kaa haath mujhe thaamegaa",
          "Main nahin daroongaa"
        ]
      }
    ]
  },
