          "हम पर उँड़ेल दे",
          "अग्नि बनकर उतर आ",
          "सामर्थ से भर दे"
        ],
        "linesRomanized": [
          "Pavitra Aatma aa, aa",
          "Ham par undel de",
          "Agni bankar utar aa",
          "Saamarth se bhar de"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "पिन्तेकुस्त के दिन जैसे",
          "अग्नि की जीभों जैसे",
          "उतर आ पवित्र आत्मा",
          "हमें अपना बना ले"
        ],
        "linesRomanized": [
          "Pintekust ke din jaise",
          "Agni ki jeebhon jaise",
          "Utar aa Pavitra Aatma",
          "Hamein apnaa banaa le"
