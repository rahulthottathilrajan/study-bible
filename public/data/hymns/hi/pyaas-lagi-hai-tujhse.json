  "story": "A deeply devotional bhajan expressing the soul's intense longing for God. Based on the psalmist's cry in Psalm 42, this traditional Hindi hymn captures the thirst of a heart that finds rest only in the presence of the living God. It is a favorite during Lenten devotions and quiet worship.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "प्यास लगी है तुझसे",
          "जैसे हिरन पानी को चाहे",
          "मेरी आत्मा तुझको चाहे",
          "जीवित देव तुझको चाहे"
        ],
        "linesRomanized": [
          "Pyaas lagi hai tujhse",
          "Jaise hiran paani ko chaahe",
          "Meri aatmaa tujhko chaahe",
          "Jeevit Dev tujhko chaahe"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "कब आऊँगा मैं",
          "देव की उपस्थिति में खड़ा होऊँगा",
          "आँसू मेरा भोजन बने",
          "तेरा मुख ढूँढ रहा हूँ"
        ],
        "linesRomanized": [
          "Kab aaoongaa main",
          "Dev ki upasthiti mein khadaa hoongaa",
          "Aansoo meraa bhojan bane",
          "Teraa mukh dhoondh rahaa hoon"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "क्यों उदास है मेरी आत्मा",
          "देव पर भरोसा रख",
          "उसके मुख के उद्धार को",
          "फिर से स्तुति करूँगा मैं"
        ],
        "linesRomanized": [
          "Kyon udaas hai meri aatmaa",
          "Dev par bharosaa rakh",
          "Uske mukh ke uddhaar ko",
          "Phir se stuti karoongaa main"
        ]
      }
    ]
  },
