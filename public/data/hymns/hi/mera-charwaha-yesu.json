  "story": "A tender shepherd-psalm bhajan based on Psalm 23. This beloved Hindi hymn has comforted countless believers through seasons of grief and uncertainty. Its gentle melody carries the reassuring promise of God's constant care through every valley and beside every still water.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "मेरा चरवाहा यीशु है",
          "मुझको कमी नहीं",
          "हरी चराइयों में चराता",
          "शान्त जल के पास ले जाता"
        ],
        "linesRomanized": [
          "Meraa charwaahaa Yeshu hai",
          "Mujhko kamee nahin",
          "Haree charaaiyion mein charaataa",
          "Shaant jal ke paas le jaataa"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "मौत की छाया की तराई में भी",
          "मैं नहीं डरूँगा",
          "तू मेरे साथ है",
          "तेरी लाठी और छड़ी मुझे तसल्ली देती"
        ],
        "linesRomanized": [
          "Maut ki chhaayaa ki taraaee mein bhi",
          "Main nahin daroongaa",
          "Tu mere saath hai",
          "Teri laathi aur chhadee mujhe tassali deti"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "भलाई और दया",
          "मेरे जीवन भर",
          "मेरा पीछा करेगी",
          "प्रभु के घर में रहूँगा"
        ],
        "linesRomanized": [
          "Bhalaaee aur dayaa",
          "Mere jeevan bhar",
          "Meraa peechhaa karegee",
          "Prabhu ke ghar mein rahoongaa"
        ]
      }
    ]
  },
