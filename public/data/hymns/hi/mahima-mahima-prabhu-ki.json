          "सब कुछ रचने वाले का",
          "महिमा महिमा"
        ],
        "linesRomanized": [
          "Aakaash aur prithvi ko",
          "Banaane waale kaa",
          "Sab kuchh rachne waale kaa",
          "Mahimaa mahimaa"
