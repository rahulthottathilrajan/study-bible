  "story": "A beloved hymn of assurance rooted in the Telugu Christian heritage of Andhra Pradesh. Based on Paul's testimony in 2 Corinthians, this keerthanamu has been a source of strength for believers enduring hardship. It is especially cherished in rural Telugu church communities where faith sustains people through daily struggles.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "నీ కృప చాలు నీ కృప చాలు",
          "ప్రభువా నీ కృప నాకు చాలు",
          "బలహీనతలో నీ బలము చాలు"
        ],
        "linesRomanized": [
          "Nee krupa chaalu nee krupa chaalu",
          "Prabhuvaa nee krupa naaku chaalu",
          "Balaheenathalo nee balamu chaalu"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "శోధనలు వచ్చినా భయము లేదు",
          "కష్టములు వచ్చినా కలత లేదు",
          "నీవు నాతో ఉన్నావు అదే చాలు",
          "ప్రభువా నీ కృప నాకు చాలు"
        ],
        "linesRomanized": [
          "Shodhanalu vacchinaa bhayamu ledu",
          "Kashtamulu vacchinaa kalatha ledu",
          "Neevu naatho unnaavu ade chaalu",
          "Prabhuvaa nee krupa naaku chaalu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "లోకం నన్ను విడిచినా నీవుంటే చాలు",
          "ఆస్తులు పోయినా నీ కృప చాలు",
          "అన్నీ కోల్పోయినా యేసు నాకు చాలు",
          "ప్రభువా నీ కృప నాకు చాలు"
        ],
        "linesRomanized": [
          "Lokam nannu vidicinaa neevunte chaalu",
          "Aasthulu poyinaa nee krupa chaalu",
          "Annee kolpoyinaa Yesu naaku chaalu",
          "Prabhuvaa nee krupa naaku chaalu"
        ]
      }
    ]
  },
