  "story": "A joyful Telugu Christmas keerthanamu celebrating the birth of Jesus in Bethlehem. This traditional carol has been a highlight of Christmas celebrations in Andhra Pradesh and Telangana for generations. Churches come alive with its festive melody during the Advent season, bringing together families in celebration of the Saviour's birth.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "బేత్లెహేములోని రాజా",
          "దావీదు పట్టణపు రాజా",
          "రక్షకుడు పుట్టెను",
          "లోక రక్షకుడు పుట్టెను"
        ],
        "linesRomanized": [
          "Bethlehemloni raajaa",
          "Daaveedu pattanapu raajaa",
          "Rakshakudu puttenu",
          "Loka rakshakudu puttenu"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "దేవదూతలు పాడిరి",
          "గొర్రెల కాపరులు వచ్చిరి",
          "నక్షత్రము దారి చూపగా",
          "జ్ఞానులు కూడా వచ్చిరి"
        ],
        "linesRomanized": [
          "Devadoothalu paadiri",
          "Gorrela kaaparulu vachhiri",
          "Nakshatramu daari choopaga",
          "Gnaanulu koodaa vachhiri"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "పశువుల పాకలో పుట్టెను",
          "దీనులను రక్షించగా",
          "దేవ కుమారుడు వచ్చెను",
          "మానవులను మీడ్చగా"
        ],
        "linesRomanized": [
          "Pashuvula paakalo puttenu",
          "Deenulanu rakshinchagaa",
          "Deva kumaarudu vachhenu",
          "Maanavulanu meedchagaa"
        ]
      }
    ]
