  "scriptureRefs": [
    {
      "ref": "Genesis 22:14",
      "note": "Abraham called the name of that place Jehovahjireh"
    },
    {
      "ref": "Philippians 4:19",
      "note": "My God shall supply all your need"
    }
  ],
  "story": "A keerthanamu celebrating God's names and His faithful provision. Drawing from Abraham's encounter on Mount Moriah, this traditional hymn declares that God sees and provides for every need. It is a beloved testimony hymn in Telugu churches.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "యెహోవా యీరే సమకూర్చు దేవుడు",
          "యెహోవా షాలోం సమాధానము",
          "యెహోవా నిస్సీ జయమిచ్చు దేవుడు",
          "యెహోవా నా దేవుడు"
        ],
        "linesRomanized": [
          "Yehovaa yeereh samakoorchu devudu",
          "Yehovaa shaalom samaadhaanamu",
          "Yehovaa nissee jayamichu devudu",
          "Yehovaa naa devudu"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "అవసరములన్ని ఎరిగినవాడు",
          "తగిన సమయములో ఇచ్చువాడు",
          "మహిమ ఐశ్వర్యములో నుండి",
          "సమస్తము ఇచ్చును దేవుడు"
        ],
        "linesRomanized": [
          "Avasaramulanni eriginavaadu",
          "Thagina samayamulo icchhuvaadu",
          "Mahima aishwaryamulo nundi",
          "Samastamu ichchunu devudu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "అబ్రాహాము దేవుడు",
          "ఇస్సాకు దేవుడు",
          "యాకోబు దేవుడు",
          "ఇప్పటికీ జీవించు దేవుడు"
        ],
        "linesRomanized": [
          "Abraahaamu devudu",
          "Issaaku devudu",
          "Yaakobu devudu",
          "Ippatikee jeevainchu devudu"
        ]
      }
    ]
  },
