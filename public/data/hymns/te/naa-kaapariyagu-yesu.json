  "story": "A tender shepherd-psalm keerthanamu based on Psalm 23. This beloved Telugu hymn has comforted countless believers in Andhra Pradesh and Telangana through seasons of grief and trial. Its gentle melody carries the reassuring promise of God's constant care.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "నా కాపరియగు యేసు",
          "నాకు లేమి లేదు",
          "పచ్చిక బయళ్ళలో మేపును",
          "నిదానమైన నీళ్ళ యొద్దకు నడిపించును"
        ],
        "linesRomanized": [
          "Naa kaapariyagu Yesu",
          "Naaku lemi ledu",
          "Pachchika bayallalo mepunu",
          "Nidaanamaina neella yoddaku nadipinchunu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "మరణపు నీడ లోయలో నడచినను",
          "నేను భయపడను",
          "నీవు నాతో ఉన్నావు",
          "నీ కర్ర నీ దండము నన్ను ఆదరించును"
        ],
        "linesRomanized": [
          "Maranapu needa loyalo nadachinanu",
          "Nenu bhayapadanu",
          "Neevu naatho unnaavu",
          "Nee karra nee dandamu nannu aadarinchunu"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "మేలు కృపయు",
          "నా దినములన్నియు",
          "నన్ను వెంబడించును",
          "ప్రభువు ఇంట నేను నివసించెదను"
        ],
        "linesRomanized": [
          "Melu krupayau",
          "Naa dinamulanniyu",
          "Nannu vembadinchunu",
          "Prabhuvau inta nenu nivasincheedanu"
        ]
      }
    ]
  },
