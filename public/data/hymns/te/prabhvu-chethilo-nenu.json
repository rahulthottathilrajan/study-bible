{
  "id": "prabhvu-chethilo-nenu",
  "lang": "te",
  "title": "ప్రభువు చేతిలో నేను",
  "titleRomanized": "Prabhuvu Chethilo Nenu",
  "author": "Traditional",
  "composer": "Traditional Telugu melody",
  "year": null,
  "categories": [
    "comfort",
    "grace"
  ],
  "scriptureRefs": [
    {
      "ref": "Isaiah 49:16",
      "note": "I have graven thee upon the palms of my hands"
    },
    {
      "ref": "John 10:28",
      "note": "Neither shall any man pluck them out of my hand"
    }
  ],
  "story": "A keerthanamu of deep assurance reminding believers they are held securely in God's hands. This traditional hymn draws from the tender image in Isaiah of God engraving His children on His palms. It has brought immeasurable comfort during times of loss in Telugu Christian communities.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ప్రభువు చేతిలో నేను",
          "భద్రముగా ఎల్లప్పుడు",
          "ఎవరును లాగలేరు",
          "నన్ను ఆయన చేతిలో నుండి"
        ],
        "linesRomanized": [
          "Prabhuvu chethilo nenu",
          "Bhadramugaa ellappudu",
          "Evarunu laagaleru",
          "Nannu aayana chethilo nundi"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "అరచేతిలో చెక్కియున్నాడు",
          "నా పేరు ఆయన",
          "మరువడు ఎన్నటికీ",
          "నన్ను ఆయన ప్రేమించును"
        ],
        "linesRomanized": [
          "Arachethilo chekkiyunnaadu",
          "Naa peru aayana",
          "Maruvadu ennatikee",
          "Nannu aayana preminchunu"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "తుఫాను వచ్చినా",
          "వరదలు వచ్చినా",
          "ప్రభువు చేయి నన్ను భరించును",
          "నేను భయపడను"
        ],
        "linesRomanized": [
          "Thufaanu vachhinaa",
          "Varadalu vachhinaa",
          "Prabhuvau cheyi nannu bharinchunu",
          "Nenu bhayapadanu"
        ]
      }
    ]
  },
  "translations": [],
  "publicDomain": true,
  "source": "Traditional Telugu Christian Heritage"
}