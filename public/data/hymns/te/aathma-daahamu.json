  "scriptureRefs": [
    {
      "ref": "Psalm 42:1",
      "note": "As the hart panteth after the water brooks, so panteth my soul after thee"
    },
    {
      "ref": "Psalm 63:1",
      "note": "My soul thirsteth for thee"
