  "story": "A deeply devotional keerthanamu expressing the soul's intense longing for God. Based on the psalmist's cry in Psalm 42, this traditional Telugu hymn captures the thirst of a heart that finds rest only in the presence of the living God. It is a favorite during Lenten devotions and evening worship.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ఆత్మ దాహము నీ మీద",
          "లేడి నీటిని కోరినట్లు",
          "నా ఆత్మ నిన్ను కోరుచున్నది",
          "జీవముగల దేవా"
        ],
        "linesRomanized": [
          "Aathma daahamu nee meeda",
          "Ledi neetini korinatlu",
          "Naa aathma ninnu koruchunnadhi",
          "Jeevamugala devaa"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ఎప్పుడు వచ్చెదను నేను",
          "దేవుని సన్నిధిలో నిలచెదను",
          "కన్నీరు నా ఆహారమాయెను",
          "నీ ముఖము వెదకుచున్నాను"
        ],
        "linesRomanized": [
          "Eppudu vachchedanu nenu",
          "Devuni sannidhilo nilachedanu",
          "Kanneeru naa aahaaramaayenu",
          "Nee mukhamu vedakuchunnaanu"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ఏల కలత చెందెదవు నా ఆత్మా",
          "దేవుని నమ్ముకో",
          "ఆయన ముఖ రక్షణను",
          "ఇంకను స్తుతించెదను నేను"
        ],
        "linesRomanized": [
          "Ela kalatha chendedavu naa aathmaa",
          "Devuni nammuko",
          "Aayana mukha rakshananu",
          "Inkanu sthutinchedanu nenu"
        ]
      }
    ]
  },
