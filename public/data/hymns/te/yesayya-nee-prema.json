        "type": "chorus",
        "lines": [
          "యేసయ్యా నీ ప్రేమ ఎంతో గొప్పది",
          "యేసయ్యా నీ కృప ఎన్నో మేళ్ళు",
          "లోకమంతా విడిచినా నీవు విడువని ప్రేమ"
        ],
        "linesRomanized": [
