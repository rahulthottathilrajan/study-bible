  "story": "A hymn of patient trust drawn from Isaiah 40, beloved in Telugu prayer meetings. This keerthanamu encourages believers to wait upon the Lord with renewed hope and strength, promising that those who trust will soar like eagles above their circumstances.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ఎదురు చూస్తున్నాను ప్రభువా",
          "బలము నూతనపరచెదవు",
          "గద్ద వలె ఎగురుదును",
          "అలయను సొలయను"
        ],
        "linesRomanized": [
          "Eduru choosthunnanu Prabhuvaa",
          "Balamu nootanaparachedavu",
          "Gadda vale egurudunu",
          "Alayanu solayanu"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "పరుగెత్తుదును అలయను",
          "నడచెదను సొలయను",
          "ప్రభువు కొరకు ఎదురుచూచువారు",
          "బలము పొందెదరు"
        ],
        "linesRomanized": [
          "Parugetthudunu alayanu",
          "Nadachedanu solayanu",
          "Prabhuvau koraku eduruchoochuvaru",
          "Balamu pondedaru"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "బాలురు అలసినను",
          "యౌవనస్తులు తొట్రిల్లినను",
          "ప్రభువును నమ్ముకొనువారు",
          "ఎన్నటికీ పడిపోరు"
        ],
        "linesRomanized": [
          "Baaluru alasinanu",
          "Yauvanasthulu tottrillinanu",
          "Prabhuvunu nammukonuvaaru",
          "Ennatikee padipooru"
        ]
      }
    ]
  },
