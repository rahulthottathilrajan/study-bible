  "story": "A beloved Telugu Sunday School song that has introduced generations of children to the love of Jesus. This simple, joyful keerthanamu uses repetitive phrases and a catchy melody that children can easily learn and sing along with. It is a staple of children's church services and Vacation Bible School programs throughout Andhra Pradesh.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "చిన్నారులకు యేసున్నాడు",
          "చిన్నారులను యేసు ప్రేమిస్తాడు",
          "రండి రండి పిల్లలారా",
          "యేసు దగ్గరకు రండి"
        ],
        "linesRomanized": [
          "Chinnaarulaku Yesunnaadu",
          "Chinnaarulanu Yesu premisthaadu",
          "Randi randi pillalaaraa",
          "Yesu daggaraku randi"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "చిన్న చిన్న చేతులతో",
          "దేవుని స్తుతించండి",
          "చిన్న చిన్న గొంతులతో",
          "పాటలు పాడండి"
        ],
        "linesRomanized": [
          "Chinna chinna chethulathoa",
          "Devuni sthuthinchandi",
          "Chinna chinna gontulathoa",
          "Paatalu paadandi"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "యేసు మిమ్మల్ని ప్రేమిస్తాడు",
          "యేసు మిమ్మల్ని కాపాడతాడు",
          "ఆయన రాజ్యము మీదే",
          "పిల్లలారా సంతోషించండి"
        ],
        "linesRomanized": [
          "Yesu mimmalni premisthaadu",
          "Yesu mimmalni kaapaadathadu",
          "Aayana raajyamu meedae",
          "Pillalaaraa santhoshinchandi"
        ]
      }
    ]
