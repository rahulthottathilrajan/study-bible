  "story": "A spirited missionary keerthanamu from the Telugu church tradition. This hymn has inspired Telugu Christians across generations to carry the message of salvation to every corner of the land. It is a beloved anthem at mission conferences and evangelistic gatherings throughout Andhra Pradesh and Telangana.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "సువార్త వినండి సువార్త వినండి",
          "యేసు రక్షణ సువార్త వినండి",
          "లోకమంతటా ప్రకటించండి",
          "దేవుని ప్రేమ తెలియజేయండి"
        ],
        "linesRomanized": [
          "Suvaartha vinandi suvaartha vinandi",
          "Yesu rakshana suvaartha vinandi",
          "Lokamanthataa prakatinchandi",
          "Devuni prema teliyajeyandi"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "అన్ని జాతులకు చెప్పండి",
          "అన్ని భాషలలో పాడండి",
          "రక్షణ వార్తను అందించండి",
          "ప్రభువు పంపుతున్నాడు మనలను"
        ],
        "linesRomanized": [
          "Anni jaathulaku cheppandi",
          "Anni bhaashalalo paadandi",
          "Rakshana vaarthanu andinchandi",
          "Prabhuvau pamputhunnaadu manalanu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "కొండలు దాటి లోయలు దాటి",
          "సముద్రాలు దాటి వెళ్ళండి",
          "ప్రభువు పని చేయండి",
          "ఆత్మలను సంపాదించండి"
        ],
        "linesRomanized": [
          "Kondalu daati loyalu daati",
          "Samudraalu daati vellandi",
          "Prabhuvau pani cheyandi",
          "Aathmalanu sampadinchandi"
        ]
      }
    ]
  },
