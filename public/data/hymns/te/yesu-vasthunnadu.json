  "story": "A keerthanamu of eager anticipation for Christ's Second Coming. This traditional Telugu hymn reflects the eschatological hope central to Andhra Christian worship. Its building melody stirs hearts to live in readiness for the glorious return of the King.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "యేసు వస్తున్నాడు యేసు వస్తున్నాడు",
          "మేఘముల మీద వస్తున్నాడు",
          "మహిమతో వస్తున్నాడు",
          "త్వరగా వస్తున్నాడు ప్రభువు"
        ],
        "linesRomanized": [
          "Yesu vasthunnadu Yesu vasthunnadu",
          "Meghamula meeda vasthunnadu",
          "Mahimatho vasthunnadu",
          "Thvaraga vasthunnadu Prabhuvau"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "బూర ఊదబడు నాడు",
          "మృతులు లేచెదరు",
          "సజీవులు మార్పు పొందెదరు",
          "ప్రభువుతో చేరెదరు"
        ],
        "linesRomanized": [
          "Boora oodabadu naadu",
          "Mruthulu lechedaru",
          "Sajeevulu maarpu pondedaru",
          "Prabhuvutho cheredaru"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "సిద్ధపడి ఉండండి",
          "దీపములు వెలిగించండి",
          "పెండ్లి కుమారుడు వస్తున్నాడు",
          "ఆమేన్ రండి ప్రభువా"
        ],
        "linesRomanized": [
          "Siddhapadi undandi",
          "Deepamulu veliginchandi",
          "Pendli kumaarudu vasthunnadu",
          "Aamen randi Prabhuvaa"
        ]
      }
    ]
  },
