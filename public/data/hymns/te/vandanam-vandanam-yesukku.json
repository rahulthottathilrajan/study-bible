  "story": "A reverent worship keerthanamu from the traditional Telugu church. This classic hymn of adoration has been the opening song of worship services in Andhra Pradesh for generations. Its dignified melody and words of reverence set the tone for a congregational encounter with the living God.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "వందనం వందనం యేసుక్కు",
          "స్తుతులు స్తుతులు ప్రభుక్కు",
          "ఆరాధన ఆరాధన",
          "మా దేవునికి ఆరాధన"
        ],
        "linesRomanized": [
          "Vandanam vandanam Yesukku",
          "Sthuthulu sthuthulu Prabhukku",
          "Aaradhana aaradhana",
          "Maa Devuniki aaradhana"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "సాగిలపడి ఆరాధిద్దాం",
          "మోకరించి స్తుతిద్దాం",
          "మనలను చేసిన దేవుని",
          "హృదయంతో కొనియాడుదాం"
        ],
        "linesRomanized": [
          "Saagilapadi aaradhiddaam",
          "Mokarinchi sthuthiddaam",
          "Manalanu chesina Devuni",
          "Hrudayantho koniyaadudaam"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "దేవదూతలు ఆరాధించు",
          "సకల సృష్టి కీర్తించు",
          "మేమును నీ ముందు నిలిచి",
          "ఘనపరచుచున్నాము ప్రభూ"
        ],
        "linesRomanized": [
          "Devadoothalu aaradhinchu",
          "Sakala srushti keerthinchu",
          "Memunu nee mundu nilichi",
          "Ghanaparachuchunnaamu Prabhoo"
        ]
      }
    ]
  },
