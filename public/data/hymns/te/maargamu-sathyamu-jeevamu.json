    "classic"
  ],
  "scriptureRefs": [
    {
      "ref": "John 14:6",
      "note": "I am the way, the truth, and the life"
    },
    {
      "ref": "John 11:25",
      "note": "I am the resurrection, and the life"
    }
  ],
  "story": "A profound keerthanamu based on Christ's 'I Am' declarations in John's Gospel. This traditional Telugu hymn invites believers into deep meditation on who Jesus truly is. It has been sung with reverence and conviction in Telugu churches for generations.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "మార్గమును సత్యమును జీవమును",
          "నీవే యేసువా",
          "నీ ద్వారా తప్ప",
          "తండ్రి యొద్దకు ఎవరును రారు"
        ],
        "linesRomanized": [
          "Maargamu sathyamu jeevamu",
          "Neevae Yesuvaa",
          "Nee dwaaraa thappa",
          "Thandri yoddaku evarunu raaru"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "నేను మంచి కాపరిని",
          "గొర్రెల కొరకు ప్రాణమిచ్చెదను",
          "నేను పునరుత్థానమును జీవమును",
          "నమ్మువాడు జీవించును"
        ],
        "linesRomanized": [
          "Nenu manchi kaaparini",
          "Gorrela koraku praanamichedanu",
          "Nenu punaruththaanamunu jeevamunu",
          "Nammuvaadu jeevainchunu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "నేను లోకమునకు వెలుగును",
          "నన్ను వెంబడించువాడు",
          "చీకటిలో నడువడు",
          "జీవపు వెలుగు కలిగియుండును"
        ],
        "linesRomanized": [
          "Nenu lokamunaku velugunu",
          "Nannu vembadinchuvadu",
          "Cheekatilo naduvadu",
          "Jeevapu velugu kaligiyundunu"
        ]
      }
    ]
  },
