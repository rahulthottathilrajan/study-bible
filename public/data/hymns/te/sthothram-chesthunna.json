  "story": "One of the most widely recognized Telugu Christian praise songs, sung across Andhra Pradesh and Telangana in virtually every denomination. This traditional keerthanamu expresses continual thanksgiving and praise to God for His countless blessings. It has been a cornerstone of Telugu Christian worship for generations.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "స్తోత్రం చేస్తున్నా నిన్ను స్తోత్రం చేస్తున్నా",
          "నా యేసయ్యా నిన్ను స్తోత్రం చేస్తున్నా",
          "హల్లెలూయ స్తోత్రం చేస్తున్నా"
        ],
        "linesRomanized": [
          "Sthothram chesthunna ninnu sthothram chesthunna",
          "Naa Yesayyaa ninnu sthothram chesthunna",
          "Hallelujah sthothram chesthunna"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "పాపములో ఉన్న నన్ను వెదకి వచ్చినావు",
          "నీ రక్తముతో నన్ను కడిగి శుద్ధి చేసినావు",
          "అందుకే నిన్ను స్తోత్రం చేస్తున్నా"
        ],
        "linesRomanized": [
          "Paapamulo unna nannu vedaki vacchinavu",
          "Nee rakthamutho nannu kadigi shuddhi chesinavu",
          "Anduke ninnu sthothram chesthunna"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "కష్టములో ఉన్నప్పుడు నన్ను ఓదార్చినావు",
          "కన్నీళ్ళన్నీ తుడిచి ఆదరించినావు",
          "అందుకే నిన్ను స్తోత్రం చేస్తున్నా"
        ],
        "linesRomanized": [
          "Kashtamulo unnappudu nannu odarcinavu",
          "Kanneellanni tudichi adarincinavu",
          "Anduke ninnu sthothram chesthunna"
        ]
      }
    ]
  },
