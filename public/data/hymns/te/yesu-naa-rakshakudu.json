  "story": "A deeply personal keerthanamu declaring Jesus as the one true Saviour. This traditional hymn has been a cornerstone of Telugu Protestant worship for generations, expressing the believer's complete trust and devotion to Christ as Lord and Redeemer.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "యేసు నా రక్షకుడు నా ప్రభువు",
          "యేసు నా ఆధారము నా దేవుడు",
          "ఆయనే నా సర్వస్వము",
          "ఆయనను నేను స్తుతించెదను"
        ],
        "linesRomanized": [
          "Yesu naa rakshakudu naa prabhuvau",
          "Yesu naa aadhaaramu naa devudu",
          "Aayanae naa sarvasvamu",
          "Aayananu nenu sthutinchedanu"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "చీకటిలో వెలుగైనవాడు",
          "ఎడారిలో దారిచూపినవాడు",
          "తుఫానులో శాంతినిచ్చినవాడు",
          "యేసు నా రక్షకుడు"
        ],
        "linesRomanized": [
          "Cheekatilo velugaainavaadu",
          "Edaarilo daarichoopinavaadu",
          "Thufaanulo shaanthinichinavaadu",
          "Yesu naa rakshakudu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "రోగములో స్వస్థతనిచ్చినవాడు",
          "దుఃఖములో ఆదరణిచ్చినవాడు",
          "మరణములో జీవమిచ్చినవాడు",
          "యేసు నా రక్షకుడు"
        ],
        "linesRomanized": [
          "Rogamulo svasthathanichchinavaadu",
          "Duhkhamulo aadaranichinavaadu",
          "Maranamulo jeevamichinavaadu",
          "Yesu naa rakshakudu"
        ]
      }
    ]
  },
