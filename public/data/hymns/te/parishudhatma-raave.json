  "story": "A powerful invocation keerthanamu sung across Pentecostal and charismatic churches in Andhra Pradesh and Telangana. This traditional hymn is the centerpiece of revival meetings, calling upon the Holy Spirit to descend with power and fire. Its stirring melody has accompanied countless moments of spiritual renewal.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "పరిశుద్ధాత్మ రావే రావే",
          "మా మీద కుమ్మరించు",
          "అగ్నిగా దిగి రావే",
          "బలముతో నింపుమా"
        ],
        "linesRomanized": [
          "Parishudhatma raave raave",
          "Maa meeda kummarinchu",
          "Agnigaa digi raave",
          "Balamutho nimpumaa"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "పెంతేకొస్తు దినమందు వలె",
          "అగ్ని నాలుకలు వలె",
          "దిగి రావే ఆత్మమా",
          "మమ్ములను ఆవరించు"
        ],
        "linesRomanized": [
          "Penthekostu dinamandu vale",
          "Agni naalukalu vale",
          "Digi raave aathmamaa",
          "Mammulanu aavarainchu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "వరములను దయచేయుము",
          "శక్తిని అనుగ్రహించు",
          "సాక్షులుగా మార్చుము",
          "పరిశుద్ధాత్మ రావే"
        ],
        "linesRomanized": [
          "Varamulanu dayacheyumu",
          "Shakthini anugrahainchu",
          "Saakshulugaa maarchumu",
          "Parishudhatma raave"
        ]
      }
    ]
  },
