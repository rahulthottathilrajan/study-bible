          "Sthothra maado devarige",
          "Aatana krupe endendigoo",
          "Sthothra maado nanna manave"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಪಾಪಗಳ ಕ್ಷಮಿಸಿದಾತನು",
          "ರೋಗಗಳ ವಾಸಿ ಮಾಡಿದನು",
          "ನಾಶನದಿಂದ ಬಿಡಿಸಿದನು",
          "ಕೃಪೆ ಕರುಣೆ ಮುಕುಟ ಇಟ್ಟನು"
        ],
        "linesRomanized": [
          "Paapagala kshamishidaatanu",
          "Rogagala vaasi maadidanu",
          "Naashanadinda bidisidanu",
          "Krupe karune mukuta ittanu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
