          "ದೇವರು ನಮ್ಮನು ಕರುಣಿಸುವನು",
          "ನಾವು ಮಣ್ಣೆಂದು ಬಲ್ಲವನು",
          "ಆತನ ಕೃಪೆ ಶಾಶ್ವತವು"
        ],
        "linesRomanized": [
          "Appanu makkala karunisuvante",
          "Devaru nammanu karunisuvanu",
          "Naavu mannendu ballavanu",
          "Aatana krupe shaashwatavu"
        ]
