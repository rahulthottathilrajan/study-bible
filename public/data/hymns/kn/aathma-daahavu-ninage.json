  "scriptureRefs": [
    {
      "ref": "Psalm 42:1",
      "note": "As the hart panteth after the water brooks, so panteth my soul after thee"
    },
    {
      "ref": "Psalm 63:1",
      "note": "My soul thirsteth for thee"
    }
  ],
  "story": "A deeply devotional keerthane expressing the soul's intense longing for God. Based on the psalmist's cry in Psalm 42, this traditional Kannada hymn captures the thirst of a heart that finds rest only in God's presence. It is a favorite during Lenten devotions and evening prayer meetings.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಆತ್ಮ ದಾಹವು ನಿನಗೆ",
          "ಜಿಂಕೆ ನೀರನ್ನು ಬಯಸುವಂತೆ",
          "ನನ್ನ ಆತ್ಮ ನಿನ್ನನ್ನು ಬಯಸುತ್ತದೆ",
          "ಜೀವವುಳ್ಳ ದೇವರೇ"
        ],
        "linesRomanized": [
          "Aathma daahavu ninage",
          "Jinke neerannu bayasuvante",
          "Nanna aathma ninnannu bayasuttade",
          "Jeevavulla Devare"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಯಾವಾಗ ಬರುವೆನು ನಾನು",
          "ದೇವರ ಸನ್ನಿಧಿಯಲ್ಲಿ ನಿಲ್ಲುವೆನು",
          "ಕಣ್ಣೀರೇ ನನ್ನ ಆಹಾರವಾಯಿತು",
          "ನಿನ್ನ ಮುಖ ಹುಡುಕುತ್ತಿದ್ದೇನೆ"
        ],
        "linesRomanized": [
          "Yaavaaga baruvenu naanu",
          "Devara sannidhiyalli nilluvenu",
          "Kanneere nanna aahaaravayithu",
          "Ninna mukha hudukuttiddene"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ಏಕೆ ಕಳವಳಪಡುವೆ ನನ್ನ ಆತ್ಮವೇ",
          "ದೇವರನ್ನು ನಂಬು",
          "ಆತನ ಮುಖದ ರಕ್ಷಣೆಯನ್ನು",
          "ಇನ್ನೂ ಸ್ತುತಿಸುವೆನು ನಾನು"
        ],
        "linesRomanized": [
          "Eke kalavalapaduve nanna aathmave",
          "Devarannu nambu",
          "Aatana mukhada rakshaneyannu",
          "Innoo sthuthisuvenu naanu"
        ]
      }
    ]
  },
