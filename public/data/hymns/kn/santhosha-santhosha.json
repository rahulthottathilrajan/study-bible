  "story": "An exuberant praise keerthane that fills Karnataka churches with joy and celebration. This traditional hymn is a congregational favorite, often used to close worship services on a high note of joy. Its infectious melody and jubilant lyrics remind believers that the joy of the Lord is their strength.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ಸಂತೋಷ ಸಂತೋಷ ಯೇಸುವಿನಲ್ಲಿ",
          "ಆನಂದ ಆನಂದ ಪ್ರಭುವಿನಲ್ಲಿ",
          "ಎಂದೆಂದಿಗೂ ಸಂತೋಷಿಸಿರಿ",
          "ಮತ್ತೊಮ್ಮೆ ಹೇಳುವೆ ಸಂತೋಷಿಸಿರಿ"
        ],
        "linesRomanized": [
          "Santhosha santhosha Yesuvinalli",
          "Aananda aananda Prabhuvnalli",
          "Endendigoo santhoshisiri",
          "Matthomme heluve santhoshisiri"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಪ್ರಭುವಿನ ಸನ್ನಿಧಿಯಲ್ಲಿ",
          "ಪೂರ್ಣ ಆನಂದವಿದೆ",
          "ಆತನ ಬಲಗಡೆಯಲ್ಲಿ",
          "ನಿತ್ಯ ಸುಖವಿದೆ"
        ],
        "linesRomanized": [
          "Prabhuvina sannidhiyalli",
          "Poorna aanandavide",
          "Aatana balagadeyalli",
          "Nithya sukhavide"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಕಷ್ಟದಲ್ಲೂ ಸಂತೋಷ",
          "ಸಂಕಟದಲ್ಲೂ ಆನಂದ",
          "ಪ್ರಭುವಿನ ಆನಂದವೇ",
          "ನಮ್ಮ ಬಲವಾಗಿದೆ"
        ],
        "linesRomanized": [
          "Kashtadalloo santhosha",
          "Sankatadalloo aananda",
          "Prabhuvina aanandave",
          "Namma balavaagide"
        ]
      }
    ]
