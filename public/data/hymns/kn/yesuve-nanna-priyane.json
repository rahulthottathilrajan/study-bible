  "story": "A tender devotional keerthane expressing the intimate love between the believer and Christ. Rooted in the Karnataka Christian tradition, this hymn draws on the imagery of the Song of Solomon to convey the soul's deep affection for the Saviour. It has been a favourite in both congregational worship and personal devotion among Kannada-speaking Christians.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಯೇಸುವೇ ನನ್ನ ಪ್ರಿಯನೇ",
          "ನನ್ನ ಹೃದಯದ ರಾಜನೇ",
          "ನಿನ್ನ ಪ್ರೀತಿ ಎಷ್ಟು ಶ್ರೇಷ್ಠ",
          "ನಿನ್ನಂಥವರು ಯಾರಿಲ್ಲ"
        ],
        "linesRomanized": [
          "Yesuve nanna priyane",
          "Nanna hrudayada raajane",
          "Ninna preethi eshtu shreshta",
          "Ninnanthavaru yaarilla"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಶಿಲುಬೆಯಲ್ಲಿ ನನಗಾಗಿ",
          "ಪ್ರಾಣವ ಕೊಟ್ಟ ಪ್ರಿಯನೇ",
          "ನಿನ್ನ ರಕ್ತದಿಂದ ನನ್ನ",
          "ಪಾಪ ತೊಳೆದ ದೇವನೇ"
        ],
        "linesRomanized": [
          "Shilubeyalli nanagaagi",
          "Praanava kotta priyane",
          "Ninna raktadinda nanna",
          "Paapa toleda devane"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ನಿನ್ನ ಸ್ನೇಹ ಬಿಡಲಾರೆ",
          "ನಿನ್ನ ಹಾದಿ ಬಿಡಲಾರೆ",
          "ಎಂದೆಂದಿಗೂ ನಿನ್ನವನು",
          "ಯೇಸುವೇ ನನ್ನ ಪ್ರಿಯನೇ"
        ],
        "linesRomanized": [
          "Ninna sneha bidalaare",
          "Ninna haadi bidalaare",
          "Endendigoo ninnavanu",
          "Yesuve nanna priyane"
        ]
      }
    ]
  },
