  "title": "ಪ್ರಭುವಿನ ಕೈಯಲ್ಲಿ ನಾನು",
  "titleRomanized": "Prabhuvina Kaiyalli Naanu",
  "author": "Traditional",
  "composer": "Traditional Kannada melody",
