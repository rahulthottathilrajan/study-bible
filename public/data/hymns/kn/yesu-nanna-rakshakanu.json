  "story": "A deeply personal keerthane declaring Jesus as the one true Saviour. This traditional hymn has been a cornerstone of Kannada Protestant worship, expressing the believer's complete trust and devotion to Christ. Its simple melody has strengthened the faith of generations across Karnataka.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ಯೇಸು ನನ್ನ ರಕ್ಷಕನು ನನ್ನ ಪ್ರಭು",
          "ಯೇಸು ನನ್ನ ಆಧಾರ ನನ್ನ ದೇವ",
          "ಆತನೇ ನನ್ನ ಸರ್ವಸ್ವ",
          "ಆತನನ್ನು ಸ್ತುತಿಸುವೆ"
        ],
        "linesRomanized": [
          "Yesu nanna rakshakanu nanna Prabhu",
          "Yesu nanna aadhaara nanna Deva",
          "Aatane nanna sarvasva",
          "Aatanannu sthuthisuve"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಕತ್ತಲೆಯಲ್ಲಿ ಬೆಳಕಾದವನು",
          "ಮರುಭೂಮಿಯಲ್ಲಿ ದಾರಿ ತೋರಿದವನು",
          "ಬಿರುಗಾಳಿಯಲ್ಲಿ ಶಾಂತಿ ಕೊಟ್ಟವನು",
          "ಯೇಸು ನನ್ನ ರಕ್ಷಕನು"
        ],
        "linesRomanized": [
          "Kaththaleyalli belakadavanu",
          "Marubhoomiyalli daari thoridavanu",
          "Birugaaliyalli shaanthi kottavanu",
          "Yesu nanna rakshakanu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ರೋಗದಲ್ಲಿ ಸ್ವಸ್ಥತೆ ಕೊಟ್ಟವನು",
          "ದುಃಖದಲ್ಲಿ ಸಮಾಧಾನ ಕೊಟ್ಟವನು",
          "ಮರಣದಲ್ಲಿ ಜೀವ ಕೊಟ್ಟವನು",
          "ಯೇಸು ನನ್ನ ರಕ್ಷಕನು"
        ],
        "linesRomanized": [
          "Rogadalli svasthate kottavanu",
          "Duhkhadalli samaadhana kottavanu",
          "Maranadalli jeeva kottavanu",
          "Yesu nanna rakshakanu"
        ]
      }
    ]
  },
