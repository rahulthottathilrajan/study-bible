  "story": "A keerthane celebrating God's names and faithful provision. Drawing from Abraham's encounter on Mount Moriah, this traditional hymn declares that God sees and provides for every need. It is a beloved testimony hymn in Kannada-speaking churches.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ಯೆಹೋವ ಯೀರೆ ಒದಗಿಸುವ ದೇವರು",
          "ಯೆಹೋವ ಶಾಲೋಮ್ ಶಾಂತಿ",
          "ಯೆಹೋವ ನಿಸ್ಸಿ ಜಯ ಕೊಡುವನು",
          "ಯೆಹೋವ ನನ್ನ ದೇವರು"
        ],
        "linesRomanized": [
          "Yehova Yeereh odagisva Devaru",
          "Yehova Shaalom shaanthi",
          "Yehova Nissi jaya koduvanu",
          "Yehova nanna Devaru"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಅಗತ್ಯಗಳೆಲ್ಲ ಬಲ್ಲವನು",
          "ತಕ್ಕ ಸಮಯದಲ್ಲಿ ಕೊಡುವವನು",
          "ಮಹಿಮೆಯ ಐಶ್ವರ್ಯದಿಂದ",
          "ಎಲ್ಲವನ್ನೂ ಕೊಡುವನು ದೇವರು"
        ],
        "linesRomanized": [
          "Agathyagalella ballavanu",
          "Thakka samayadalli koduvavanu",
          "Mahimeya aishwaryadinda",
          "Ellavannoo koduvanu Devaru"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಅಬ್ರಹಾಮನ ದೇವರು",
          "ಇಸಾಕನ ದೇವರು",
          "ಯಾಕೋಬನ ದೇವರು",
          "ಇಂದಿಗೂ ಜೀವಿಸುವ ದೇವರು"
        ],
        "linesRomanized": [
          "Abrahaama Devaru",
          "Isaakana Devaru",
          "Yaakobana Devaru",
          "Indigoo jeevivuva Devaru"
        ]
      }
    ]
