  "story": "A beloved worship hymn from the Karnataka Christian tradition that exalts the name of Jesus above all names. Widely sung in Basel Mission-heritage churches and CSI congregations across Karnataka, this keerthane has been a cornerstone of Kannada Christian worship for well over a century.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಯೇಸು ನಿನ್ನ ನಾಮವನ್ನ",
          "ಕೊಂಡಾಡುವೆನು ನಾನು",
          "ನಿನ್ನ ನಾಮ ಮಹಿಮೆಯನ್ನ",
          "ಹಾಡಿ ಹೊಗಳುವೆನು ನಾನು"
        ],
        "linesRomanized": [
          "Yesu ninna namavanna",
          "Kondaaduvennu naanu",
          "Ninna naama mahimeyannu",
          "Haadi hogaluvennu naanu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಎಲ್ಲ ನಾಮಕಿಂತ ಮೇಲು",
          "ಯೇಸು ಕ್ರಿಸ್ತನ ನಾಮ",
          "ಮೊಣಕಾಲೂರಿ ಅಡ್ಡಬೀಳೆ",
          "ಆ ಪರಿಶುದ್ಧ ನಾಮ"
        ],
        "linesRomanized": [
          "Ella naamakinta melu",
          "Yesu Kristana naama",
          "Monakaaluri addabiile",
          "Aa parishuddha naama"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ಸ್ವರ್ಗದಲ್ಲಿ ಭೂಮಿಯಲ್ಲಿ",
          "ಅವನ ನಾಮ ಮೇಲು",
          "ಎಲ್ಲ ಜನರು ಹಾಡಿ ಹೇಳಿ",
          "ಸ್ತುತಿಸುವರು ಆ ನಾಮ"
        ],
        "linesRomanized": [
          "Swargadalli bhoomiyalli",
          "Avana naama melu",
          "Ella janaru haadi heli",
          "Sthuthisuvaru aa naama"
        ]
      }
    ]
  },
