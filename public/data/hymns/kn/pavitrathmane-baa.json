  "story": "A fervent invocation keerthane sung across Pentecostal and charismatic churches in Karnataka. This traditional hymn calls upon the Holy Spirit to fill the congregation with power and fire. It is a centerpiece of revival meetings and prayer gatherings, setting the atmosphere for a powerful encounter with God's Spirit.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ಪವಿತ್ರಾತ್ಮನೇ ಬಾ ಬಾ",
          "ನಮ್ಮ ಮೇಲೆ ಬಂದು ತುಂಬು",
          "ಅಗ್ನಿಯಾಗಿ ಇಳಿದು ಬಾ",
          "ಶಕ್ತಿಯಿಂದ ತುಂಬಿಸು"
        ],
        "linesRomanized": [
          "Pavitrathmane baa baa",
          "Namma mele bandu thumbu",
          "Agniyaagi ilidu baa",
          "Shakthiyinda thumbisu"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಪಂಚಾಶತ್ತಮ ದಿನದಂತೆ",
          "ಅಗ್ನಿ ನಾಲಿಗೆಗಳಂತೆ",
          "ಇಳಿದು ಬಾ ಆತ್ಮನೇ",
          "ನಮ್ಮನ್ನು ಆಳು"
        ],
        "linesRomanized": [
          "Panchaashattama dinadante",
          "Agni naaligegalante",
          "Ilidu baa aathmane",
          "Nammannu aalu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ವರಗಳನ್ನು ಕೊಡು ನಮಗೆ",
          "ಬಲವನ್ನು ಅನುಗ್ರಹಿಸು",
          "ಸಾಕ್ಷಿಗಳಾಗಿ ಮಾಡು",
          "ಪವಿತ್ರಾತ್ಮನೇ ಬಾ"
        ],
        "linesRomanized": [
          "Varagalannu kodu namage",
          "Balavannu anugrahisu",
          "Saakshigalaagi maadu",
          "Pavitrathmane baa"
        ]
      }
    ]
