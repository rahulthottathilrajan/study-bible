  "story": "A deeply moving Passion keerthane from the Karnataka Christian tradition. This Lenten hymn meditates on Christ's suffering on the cross and His sacrificial love for humanity. Sung during Good Friday services and Lenten observances, its solemn melody has brought generations of Kannada believers to the foot of the cross in awe and gratitude.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಕ್ರುಶದಲ್ಲಿ ನನ್ನ ದೇವನು",
          "ನನಗಾಗಿ ಬಲಿಯಾದನು",
          "ಮುಳ್ಳು ಕಿರೀಟ ಧರಿಸಿದನು",
          "ನನ್ನ ಪಾಪಕ್ಕಾಗಿ ಸಹಿಸಿದನು"
        ],
        "linesRomanized": [
          "Krushadalli nanna devanu",
          "Nanagaagi baliyaadanu",
          "Mullu kireeeta dharisidanu",
          "Nanna paapakkaagi sahisidanu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಆತನ ಗಾಯಗಳಿಂದ",
          "ನನಗೆ ಗುಣವಾಯಿತು",
          "ಆತನ ರಕ್ತದಿಂದ",
          "ನನಗೆ ಕ್ಷಮೆ ದೊರೆಯಿತು"
        ],
        "linesRomanized": [
          "Aatana gaayagalinda",
          "Nanage gunavaayithu",
          "Aatana rakthadinda",
          "Nanage kshame doreyithu"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ಶಿಲುಬೆಯೇ ನನ್ನ ಹೆಮ್ಮೆ",
          "ಶಿಲುಬೆಯೇ ನನ್ನ ಆಶ್ರಯ",
          "ಶಿಲುಬೆಯಲ್ಲದೆ ಬೇರೇನಿಲ್ಲ",
          "ಶಿಲುಬೆಯೇ ನನ್ನ ಮಹಿಮೆ"
        ],
        "linesRomanized": [
          "Shilubeye nanna hemme",
          "Shilubeye nanna aashraya",
          "Shilubeyallade bereynilla",
          "Shilubeye nanna mahime"
        ]
      }
    ]
  },
