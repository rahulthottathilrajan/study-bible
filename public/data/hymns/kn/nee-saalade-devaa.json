  "story": "A deeply comforting hymn from the Karnataka Christian tradition affirming that God alone is sufficient for every need. Sung during times of trial and hardship, this keerthane has provided solace to Kannada-speaking Christians for generations. Its simple yet profound message of trust in God's sufficiency resonates deeply in times of grief and uncertainty.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ನೀ ಸಾಲದೇ ದೇವಾ ನನಗೆ",
          "ನಿನ್ನ ಕೃಪೆ ಸಾಲದೇ",
          "ಬಲಹೀನನಾದ ನನಗೆ",
          "ನಿನ್ನ ಬಲ ಸಾಲದೇ"
        ],
        "linesRomanized": [
          "Nee saalade devaa nanage",
          "Ninna krupe saalade",
          "Balaheenanaada nanage",
          "Ninna bala saalade"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಕಷ್ಟಗಳ ಮಧ್ಯದಲ್ಲಿ",
          "ನೀನೇ ನನ್ನ ಆಶ್ರಯ",
          "ಕಣ್ಣೀರಿನ ಕಣಿವೆಯಲ್ಲಿ",
          "ನೀನೇ ನನ್ನ ಸಮಾಧಾನ"
        ],
        "linesRomanized": [
          "Kashtagala madhyadalli",
          "Neene nanna aashraya",
          "Kanneerina kaniveyalli",
          "Neene nanna samaadhaana"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಲೋಕವೆಲ್ಲ ಬಿಟ್ಟರೂ ಸಹ",
          "ನೀನು ಬಿಡುವುದಿಲ್ಲ",
          "ಕತ್ತಲಲ್ಲಿ ನಡೆದರೂ ಸಹ",
          "ನಿನ್ನ ಬೆಳಕು ಆರದು"
        ],
        "linesRomanized": [
          "Lokavella bittaroo saha",
          "Neenu biduvudilla",
          "Kattalalli nadedaroo saha",
          "Ninna belaku aaradu"
        ]
      }
    ]
  },
