  "story": "A keerthane of patient trust drawn from Isaiah 40, beloved in Kannada prayer meetings. This hymn encourages believers to wait upon the Lord with renewed hope, promising that those who trust will soar like eagles.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ಕಾತ್ತಿರುವೆನು ಪ್ರಭುವಿನ ಕೋಸ್ಕರ",
          "ಬಲ ಹೊಸದಾಗಿ ಮಾಡುವನು",
          "ಗರುಡನಂತೆ ಹಾರುವೆನು",
          "ಬಳಲುವುದಿಲ್ಲ ಆಯಾಸವಿಲ್ಲ"
        ],
        "linesRomanized": [
          "Kaathiruvenu Prabhuvina koskara",
          "Bala hosadaagi maaduvanu",
          "Garudanante haaruvenu",
          "Balaluvudilla aayaasavilla"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ಓಡುವೆನು ಬಳಲುವುದಿಲ್ಲ",
          "ನಡೆಯುವೆನು ಆಯಾಸವಿಲ್ಲ",
          "ಪ್ರಭುವಿಗಾಗಿ ಕಾದಿರುವವರು",
          "ಬಲ ಪಡೆಯುವರು"
        ],
        "linesRomanized": [
          "Oduvenu balaluvudilla",
          "Nadeyuvenu aayaasavilla",
          "Prabhuvigaagi kaadiiruvavaru",
          "Bala padeyuvaru"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಬಾಲಕರು ಬಳಲಿದರೂ",
          "ಯೌವನಸ್ಥರು ಎಡವಿದರೂ",
          "ಪ್ರಭುವನ್ನು ನಂಬುವವರು",
          "ಎಂದಿಗೂ ಬೀಳರು"
        ],
        "linesRomanized": [
          "Baalakaru balalidharoo",
          "Yauvanastharu edavidaroo",
          "Prabhuvunnu nambuvavaru",
          "Endigoo beeaaru"
        ]
      }
    ]
  },
