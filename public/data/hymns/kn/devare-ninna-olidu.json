  "story": "A reverent worship keerthane expressing the believer's deep longing to dwell in God's presence. This hymn from the Karnataka Christian tradition captures the spirit of intimate devotion that characterized the early Basel Mission congregations in Mangalore and surrounding regions.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ದೇವರೇ ನಿನ್ನ ಒಲಿದು",
          "ನಿನ್ನ ಸನ್ನಿಧಿಯಲಿ ನಿಲ್ಲುವೆ",
          "ನಿನ್ನ ಮುಖವ ನೋಡಲು",
          "ಆಶಿಸುವೆನು ಎಂದೆಂದಿಗೂ"
        ],
        "linesRomanized": [
          "Devare ninna olidu",
          "Ninna sannithiyali nilluve",
          "Ninna mukhava nodallu",
          "Aashisuvennu endendigoo"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ನಿನ್ನ ಆಲಯದಲ್ಲಿ ಒಂದು ದಿನ",
          "ಸಾವಿರ ದಿನಕಿಂತ ಮೇಲು",
          "ನಿನ್ನ ಸೇವೆಯಲ್ಲಿ ನಿಲ್ಲುವೆ",
          "ಪರಲೋಕ ಸಂತೋಷದಲ್ಲಿ"
        ],
        "linesRomanized": [
          "Ninna aalayladalli ondu dina",
          "Saavira dinakinta melu",
          "Ninna seveyalli nilluve",
          "Paraloka santhoshadalli"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ನೀನೇ ನನ್ನ ಆಶ್ರಯ",
          "ನೀನೇ ನನ್ನ ಬಲವು",
          "ನಿನ್ನಲ್ಲಿ ನಂಬಿಕೆ ಇಟ್ಟವನು",
          "ಎಂದಿಗೂ ನಾಚಿಕೆ ಪಡನು"
        ],
        "linesRomanized": [
          "Neene nanna aashraya",
          "Neene nanna balavu",
          "Ninnalli nambike ittavanu",
          "Endigoo naachike padanu"
        ]
      }
    ]
  },
