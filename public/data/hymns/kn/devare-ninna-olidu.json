    {
      "ref": "Psalm 27:4",
      "note": "One thing have I desired of the LORD, that will I seek after; that I may dwell in the house of the LORD"
    },
    {
      "ref": "Psalm 84:10",
      "note": "A day in thy courts is better than a thousand"
