  "story": "A joyous Kannada Christmas keerthane celebrating the birth of Jesus Christ in Bethlehem. This hymn has been sung during Christmas celebrations in Karnataka churches for generations, with its festive melody bringing warmth and joy to the season. It is particularly popular in the CSI and Basel Mission-heritage congregations.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ಯೇಸು ಸ್ವಾಮಿ ಬಂದಾನೆ",
          "ಲೋಕಕೆ ರಕ್ಷಕ ಬಂದಾನೆ",
          "ಬೆತ್ಲೆಹೇಮಿನಲ್ಲಿ ಹುಟ್ಟಿದನು",
          "ಹಲ್ಲೆಲೂಯ ಹಾಡಿರಿ"
        ],
        "linesRomanized": [
          "Yesu Swami bandaane",
          "Lokake rakshaka bandaane",
          "Bethleheminalli huttidanu",
          "Hallelujah haadiri"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ತೊಟ್ಟಿಲಲ್ಲಿ ಮಲಗಿದನು",
          "ಕುರಿಗಾಹಿಗಳು ಬಂದರು",
          "ದೂತರು ಹಾಡಿದರು ಸ್ತೋತ್ರ",
          "ಮಹೋನ್ನತ ದೇವರಿಗೆ"
        ],
        "linesRomanized": [
          "Tottilalli malagidanu",
          "Kurigahigalu bandaru",
          "Dootaru haadidaru sthothra",
          "Mahonnata devarige"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ನಕ್ಷತ್ರವು ಮಾರ್ಗ ತೋರಿತು",
          "ಜ್ಞಾನಿಗಳು ಬಂದು ನಮಿಸಿದರು",
          "ಕಾಣಿಕೆಗಳ ಅರ್ಪಿಸಿದರು",
          "ರಾಜಾಧಿರಾಜನಿಗೆ"
        ],
        "linesRomanized": [
          "Nakshatravu maarga thoritu",
          "Jnaanigalu bandu namisidaru",
          "Kaanikkegala arpisidaru",
          "Raajaadhiraajanige"
        ]
      }
    ]
