  "story": "A keerthane of eager anticipation for Christ's Second Coming. This traditional Kannada hymn reflects the eschatological hope at the heart of Karnataka Christian worship. Its building melody stirs hearts to live in readiness for the King's return.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ಯೇಸು ಬರುವನು ಮತ್ತೆ ಬರುವನು",
          "ಮೇಘಗಳ ಮೇಲೆ ಬರುವನು",
          "ಮಹಿಮೆಯಿಂದ ಬರುವನು",
          "ಬೇಗನೇ ಬರುವನು ಪ್ರಭು"
        ],
        "linesRomanized": [
          "Yesu baruvanu matte baruvanu",
          "Meghagala mele baruvanu",
          "Mahimeyinda baruvanu",
          "Begane baruvanu Prabhu"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ತುತೂರಿ ಊದಲಾಗುವ ದಿನ",
          "ಮೃತರು ಎದ್ದೇಳುವರು",
          "ಜೀವಂತರು ಬದಲಾಗುವರು",
          "ಪ್ರಭುವಿನೊಂದಿಗೆ ಸೇರುವರು"
        ],
        "linesRomanized": [
          "Thuthuri oodalaaguva dina",
          "Mrutharu eddeluvaru",
          "Jeevantharu badalaaguvaru",
          "Prabhuvinondig seruvaru"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಸಿದ್ಧರಾಗಿರಿ",
          "ದೀಪ ಉರಿಸಿರಿ",
          "ಮದುಮಗನು ಬರುತ್ತಿದ್ದಾನೆ",
          "ಆಮೆನ್ ಬಾ ಪ್ರಭು ಯೇಸುವೇ"
        ],
        "linesRomanized": [
          "Siddharaagiri",
          "Deepa urisiri",
          "Madumaganu baruttiddaane",
          "Aamen baa Prabhu Yesuve"
        ]
      }
    ]
  },
