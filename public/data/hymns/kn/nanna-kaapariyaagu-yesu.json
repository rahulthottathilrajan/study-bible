  ],
  "story": "A tender shepherd-psalm keerthane based on Psalm 23. This beloved Kannada hymn has comforted believers in Karnataka through seasons of grief and trial. Its gentle melody carries the reassuring promise of God's constant care through every valley.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ನನ್ನ ಕಾಪಾರಿ ಯೇಸು",
          "ನನಗೆ ಕೊರತೆಯಿಲ್ಲ",
          "ಹಸಿರು ಹುಲ್ಲುಗಾವಲಲ್ಲಿ ಮೇಯಿಸುವನು",
          "ಶಾಂತ ನೀರಿನ ಬಳಿ ನಡೆಸುವನು"
        ],
        "linesRomanized": [
          "Nanna kaapaari Yesu",
          "Nanage korateyilla",
          "Hasiru hullugaavalalli meyisuvanu",
          "Shaantha neerina bali nadesuvanu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ಮರಣದ ನೆರಳ ಕಣಿವೆಯಲ್ಲಿ ನಡೆದರೂ",
          "ನಾನು ಭಯಪಡೆನು",
          "ನೀನು ನನ್ನೊಂದಿಗಿರುವೆ",
          "ನಿನ್ನ ಕೋಲು ದಂಡ ನನ್ನ ಸಂತೈಸುವುದು"
        ],
        "linesRomanized": [
          "Maranada nerala kaniveyalli nadedaroo",
          "Naanu bhayapadenu",
          "Neenu nannondigiruve",
          "Ninna kolu danda nanna santhaaisuvudu"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ಒಳ್ಳೆಯತನ ಕೃಪೆಯು",
          "ನನ್ನ ಜೀವಮಾನವೆಲ್ಲಾ",
          "ನನ್ನನ್ನು ಹಿಂಬಾಲಿಸುವುದು",
          "ಪ್ರಭುವಿನ ಮನೆಯಲ್ಲಿ ವಾಸಿಸುವೆನು"
        ],
        "linesRomanized": [
          "Olleyathana krupeyau",
          "Nanna jeevamaanaavellaa",
          "Nannannu himbaalisuvudu",
          "Prabhuvina maneyalli vaasisuvenu"
        ]
      }
    ]
  },
