  "story": "A beloved Tamil praise hymn rooted in Psalm 136, celebrating the enduring goodness of God. This keerthanaigal has been sung in Tamil Nadu churches for well over a century, its repetitive refrain making it ideal for congregational singing. The structure mirrors the responsive pattern of the Psalms.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "கர்த்தர் நல்லவர் கர்த்தர் நல்லவர்",
          "என்றென்றும் அவர் கிருபை உள்ளது",
          "கர்த்தர் நல்லவர் கர்த்தர் நல்லவர்"
        ],
        "linesRomanized": [
          "Karthar nallavar karthar nallavar",
          "Endrendrum avar kirupai ullathu",
          "Karthar nallavar karthar nallavar"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "வானத்தையும் பூமியையும் படைத்தவர்",
          "சூரியனையும் சந்திரனையும் வைத்தவர்",
          "எல்லா ஜீவன்களையும் காப்பவர்",
          "என்றென்றும் அவர் கிருபை உள்ளது"
        ],
        "linesRomanized": [
          "Vaanathaiym boomiyaiyum padaithavar",
          "Sooriyanaiym chantiranaiym vaithavar",
          "Ellaa jeevangalaiyum kaappavar",
          "Endrendrum avar kirupai ullathu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "எகிப்தினின்று விடுவித்தவர்",
          "செங்கடலைப் பிளந்த வல்லவர்",
          "வனாந்தரத்தில் வழிநடத்தினவர்",
          "என்றென்றும் அவர் கிருபை உள்ளது"
        ],
        "linesRomanized": [
          "Egipthininru viduvithavar",
          "Sengadalai pilantha vallavar",
          "Vanaanthirathil vazhinadathinavar",
          "Endrendrum avar kirupai ullathu"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "தாழ்மையான நிலையில் நம்மை நினைத்தவர்",
          "பகைவரிடமிருந்து மீட்டவர்",
          "சகல ஜீவனுக்கும் ஆகாரம் தருபவர்",
          "என்றென்றும் அவர் கிருபை உள்ளது"
        ],
        "linesRomanized": [
          "Thaazhmaiyaana nilaiyil nammai ninaithavar",
          "Pagaivaridamirunthu meettavar",
          "Sakala jeevanukkkum aakaaram tharubavar",
          "Endrendrum avar kirupai ullathu"
        ]
      }
    ]
  },
