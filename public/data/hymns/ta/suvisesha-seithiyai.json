  "story": "A rousing missionary keerthanaigal from the Tamil church tradition. This hymn has inspired generations of Tamil Christians to carry the gospel to unreached peoples. It is a staple at mission conferences and commissioning services, reflecting the deep evangelical heritage of Tamil Christianity.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "சுவிசேஷ செய்தியை அறிவிப்போம்",
          "இயேசுவின் அன்பை எடுத்துரைப்போம்",
          "உலகெங்கும் செல்வோம்",
          "நற்செய்தி சொல்வோம்"
        ],
        "linesRomanized": [
          "Suvisesha seithiyai arivippom",
          "Yaesuvin anbai eduthuraippom",
          "Ulagengum selvom",
          "Narcheithi solvom"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "அனைத்து ஜாதிகளுக்கும்",
          "அனைத்து மொழிகளிலும்",
          "இரட்சிப்பின் நற்செய்தி",
          "அறிவிக்க அழைக்கிறார்"
        ],
        "linesRomanized": [
          "Anaiththu jaathigalukkum",
          "Anaiththu mozhigalilum",
          "Iratchippin narcheithi",
          "Arivikka azhaikkiRaar"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "மலைகளும் கடல்களும் கடந்து",
          "தூரதேசம் சென்று",
          "கர்த்தருடைய வேலை செய்வோம்",
          "ஆத்துமாக்களை நேடுவோம்"
        ],
        "linesRomanized": [
          "Malaigalum kadalkalum kadandhu",
          "Thooradaesam senru",
          "Kartharudaiya vaelai seivom",
          "Aaththumaakkaalai naeaduvom"
        ]
      }
    ]
  },
