  "story": "One of the most widely sung praise songs in Tamil churches across denominations. This traditional keerthanaigal calls believers to come together in wholehearted worship and adoration of the Lord. It has been a cornerstone of Tamil Christian worship for generations, sung in CSI, Catholic, and Pentecostal congregations alike.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "ஆராதனை ஆராதனை",
          "இயேசுவுக்கே ஆராதனை",
          "அல்லேலூயா ஆராதனை",
          "என் தேவனுக்கே ஆராதனை"
        ],
        "linesRomanized": [
          "Aarathanai aarathanai",
          "Yesuvukkae aarathanai",
          "Allaelooyaa aarathanai",
          "En Daevanukkae aarathanai"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "வானமும் பூமியும் படைத்தவருக்கு",
          "சகலமும் உண்டாக்கினவருக்கு",
          "ஜீவனைத் தந்த தேவனுக்கு",
          "என்றென்றும் ஆராதனை"
        ],
        "linesRomanized": [
          "Vaanamum boomiyum padaithavarukkku",
          "Sakalamum undaakkinavarukkku",
          "Jeevanaith thantha Daevanukku",
          "Endrendrum aarathanai"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "பாவிகளாம் நம்மை நேசித்தவருக்கு",
          "சிலுவையில் இரத்தம் சிந்தினவருக்கு",
          "மீட்பளித்த நல்ல மேய்ப்பருக்கு",
          "என்றென்றும் ஆராதனை"
        ],
        "linesRomanized": [
          "Paavigalaam nammai naesithavarukkku",
          "Siluvayil iratham sinthinavarukku",
          "Meetpalitha nalla maeypparukku",
          "Endrendrum aarathanai"
        ]
      }
    ]
  },
