  "story": "A keerthanaigal of eager anticipation for Christ's Second Coming. This traditional hymn reflects the eschatological hope central to Tamil Christian faith. Sung with building excitement, it calls believers to live in readiness for the glorious return of the King of Kings.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "இயேசு வருவார் இயேசு வருவார்",
          "மேகங்களில் வருவார்",
          "மகிமையோடு வருவார்",
          "சீக்கிரம் வருவார் கர்த்தர்"
        ],
        "linesRomanized": [
          "Yaesu varuvar Yaesu varuvar",
          "Megangalil varuvar",
          "Magimaiiyodu varuvar",
          "Seekkiram varuvar karthar"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "எக்காளம் ஊதப்படும் நாளில்",
          "மரித்தோர் எழுவார்கள்",
          "உயிரோடு இருப்போர் மாறுவார்கள்",
          "கர்த்தரோடு சேர்வோம்"
        ],
        "linesRomanized": [
          "Ekkaalam oodhappadum naalil",
          "Mariththor ezhuvaarkal",
          "Uyirodu irupor maaruvaarkal",
          "Kartharodu seirvom"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ஆயத்தமாயிருங்கள்",
          "விளக்கை எரிய வையுங்கள்",
          "மணவாளன் வருகிறார்",
          "ஆமென் வாரும் கர்த்தாவே"
        ],
        "linesRomanized": [
          "Aayaththamaayirungal",
          "Vilakkai eriya vaiyungal",
          "Manavaalan varugiraar",
          "Aamen vaarum karthaavae"
        ]
      }
    ]
  },
