  "story": "A deeply moving Tamil meditation on Christ's sacrificial love at Calvary. This traditional Lenten hymn has been sung in Tamil churches for generations during the season leading up to Easter. Its heartfelt lyrics invite believers to contemplate the depth of God's love demonstrated through the cross.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "சிலுவை அன்பு என்ன அன்பு",
          "உலகை மீட்ட தெய்வ அன்பு",
          "பாவிகளை தேடி வந்த",
          "இயேசுவின் அளவில்லா அன்பு"
        ],
        "linesRomanized": [
          "Siluvai anbu enna anbu",
          "Ulagai meetya theiva anbu",
          "Paavigalai thaedi vandha",
          "Yaesuvin alavillaa anbu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "முள்முடி சூடி நின்றார்",
          "ஆணிகளால் அறையுண்டார்",
          "என் பாவம் சுமந்து கொண்டார்",
          "அவர் அன்பு எத்தனை பெரியது"
        ],
        "linesRomanized": [
          "Mulmudi soodi ninraar",
          "Aanigalaal araiyundaar",
          "En paavam sumandhu kondaar",
          "Avar anbu eththanai periyathu"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "இந்த அன்பை மறப்பேனோ",
          "இந்த கிருபை மறப்பேனோ",
          "என் வாழ்நாள் முழுவதும்",
          "சிலுவை அன்பை பாடுவேன்"
        ],
        "linesRomanized": [
          "Indha anbai maRappaenoa",
          "Indha kirupai maRappaenoa",
          "En vaazhnaal muzhuvathum",
          "Siluvai anbai paaduvean"
        ]
      }
    ]
  },
