  "story": "A keerthanaigal of deep assurance drawn from Isaiah's tender image of God engraving His children on His palms. This traditional hymn has brought immeasurable comfort during funerals and times of loss in Tamil Christian communities, reminding the grieving that their loved ones rest safely in God's eternal hands.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "கர்த்தர் கையில் நான்",
          "பாதுகாப்பாய் என்றும்",
          "யாரும் பிடுங்க முடியாது",
          "என்னை அவர் கையிலிருந்து"
        ],
        "linesRomanized": [
          "Karthar kaiyil naan",
          "Baadhugaappaay endrum",
          "Yaarum pidungga mudiyaadhu",
          "Ennai avar kaiyilirundu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "உள்ளங்கையில் பொறித்துள்ளார்",
          "என் பெயரை அவர்",
          "மறக்கவே மாட்டார் ஒருநாளும்",
          "என்னை அவர் நேசிப்பார்"
        ],
        "linesRomanized": [
          "Ullankaiyil poriththullaar",
          "En peyarai avar",
          "Marakkavae maattaar orunaalum",
          "Ennai avar naesippaar"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "புயல் வந்தாலும்",
          "வெள்ளம் வந்தாலும்",
          "கர்த்தர் கை என்னை தாங்கும்",
          "நான் பயப்படமாட்டேன்"
        ],
        "linesRomanized": [
          "Puyal vandhaalum",
          "Vellam vandhaalum",
          "Karthar kai ennai thaangum",
          "Naan bayappadamaatteen"
        ]
      }
    ]
  },
