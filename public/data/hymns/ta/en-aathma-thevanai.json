  "story": "A tender devotional keerthanaigal expressing the soul's deep longing for God's presence. This traditional Tamil hymn is a favorite at evening prayer meetings and personal devotion times. Its gentle melody carries the believer into a place of intimate communion with the Lord, echoing the psalmist's cry for the living God.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "என் ஆத்மா தேவனை தேடுதே",
          "என் இருதயம் உம்மை நாடுதே",
          "மான் நீர் நாடுவது போல",
          "என் ஆத்மா உம்மை நாடுதே"
        ],
        "linesRomanized": [
          "En aathma thaevanai thaeduthae",
          "En irudhayam ummai naaduthae",
          "Maan neer naaduvadhu pola",
          "En aathma ummai naaduthae"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "உம் சமூகம் இன்பமே",
          "உம் சந்நிதி பரலோகமே",
          "உம்மோடு நான் இருக்கையில்",
          "வேறொன்றும் வேண்டாமே"
        ],
        "linesRomanized": [
          "Um samoogam inbamae",
          "Um sannithi paralogamae",
          "Ummodu naan irukkaiyil",
          "Vaeronrum vaendaamae"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "காலையில் உம்மை தேடுவேன்",
          "மாலையில் உம்மை போற்றுவேன்",
          "இரவிலும் உம்மை நினைப்பேன்",
          "என்றும் உம்மை புகழ்வேன்"
        ],
        "linesRomanized": [
          "Kaalaiyil ummai thaeduvean",
          "Maalaiyil ummai potrruvean",
          "Iravilum ummai ninaippean",
          "Endrum ummai pugazhvean"
        ]
      }
    ]
