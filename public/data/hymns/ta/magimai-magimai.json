  "story": "An exuberant praise keerthanaigal declaring God's glory and majesty. This congregational hymn draws from the heavenly worship in Revelation, calling the church to ascribe all glory to God. Its stirring melody has filled Tamil churches with joyful adoration for generations.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "மகிமை மகிமை தேவனுக்கு",
          "கனம் கனம் கர்த்தருக்கு",
          "துதி துதி இயேசுவுக்கு",
          "என்றென்றும் மகிமை"
        ],
        "linesRomanized": [
          "Magimai magimai thaevanukku",
          "Ganam ganam kartharukku",
          "Thuthi thuthi Yaesuvukku",
          "Endrendrum magimai"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "வானத்தையும் பூமியையும்",
          "படைத்த தேவனுக்கு",
          "சகலத்தையும் சிருஷ்டித்த தேவனுக்கு",
          "மகிமை மகிமை"
        ],
        "linesRomanized": [
          "Vaanaththaiyum boomiyaiyum",
          "Padaiththa thaevanukku",
          "Sagalathaiyum sirushtiththa thaevanukku",
          "Magimai magimai"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "தேவதூதர்கள் ஆராதிக்கும்",
          "சேராபீன்கள் துதிக்கும்",
          "சகல சிருஷ்டியும் பாடும்",
          "மகிமை மகிமை"
        ],
        "linesRomanized": [
          "Thaevadhootharkal aaraathikkum",
          "Saeraapheenkal thuthikkum",
          "Sagala sirushttiyum paadum",
          "Magimai magimai"
        ]
      }
    ]
  },
