  "story": "A hymn of patient trust drawn from Isaiah 40, beloved in Tamil prayer meetings. This keerthanaigal encourages believers to find renewed strength through waiting on the Lord. Its steady melody carries the promise that those who trust in God will soar like eagles.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "காத்திருப்பேன் கர்த்தரில்",
          "பெலன் புதுப்பிப்பார்",
          "கழுகைப் போல எழும்புவேன்",
          "சோர்வடையேன் தளர்வடையேன்"
        ],
        "linesRomanized": [
          "Kaathiruppen kartharil",
          "Pelan puthuppippaar",
          "Kazhugaip pol ezhumbuvean",
          "Sorvadaiyean thalarvedaiyean"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ஓடுவேன் இளைப்படையேன்",
          "நடப்பேன் சோர்வடையேன்",
          "கர்த்தருக்காக காத்திருப்போர்",
          "பெலன் அடைவார்கள்"
        ],
        "linesRomanized": [
          "Oduvean ilaippadaiyean",
          "Nadappean sorvadaiyean",
          "Kartharukkaga kaathirupor",
          "Pelan adaivaarkal"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "இளைஞர்கள் இளைத்தாலும்",
          "வாலிபர்கள் மடிந்தாலும்",
          "கர்த்தரில் நம்பிக்கை வைப்போர்",
          "ஒருபோதும் வீழார்கள்"
        ],
        "linesRomanized": [
          "Ilainjarkal ilaithaalum",
          "Vaalibarkal madinthaalum",
          "Kartharil nambikkai vaipor",
          "Orupothum veezhaarkal"
        ]
      }
    ]
