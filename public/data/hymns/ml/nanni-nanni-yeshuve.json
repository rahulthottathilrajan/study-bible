          "എല്ലാറ്റിനും നന്ദി",
          "അങ്ങേക്ക് നന്ദി യേശുവേ"
        ],
        "linesRomanized": [
          "Nandi nandi Yeshuve",
          "Nandi nandi Naathane",
          "Ellaattinum nandi",
          "Angekku nandi Yeshuve"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ജീവൻ തന്നതിന് നന്ദി",
