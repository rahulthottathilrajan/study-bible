  "story": "A cherished worship hymn sung at the opening of church services across Kerala. The lyrics express the deep reverence and joy of coming before God's presence. This hymn has been part of the Kerala Christian worship tradition for well over a century.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "കർത്താവേ നിൻ സന്നിധിയിൽ",
          "ഞങ്ങളിതാ വന്നിടുന്നു",
          "ആരാധനയോടെ സ്തുതിയോടെ",
          "കർത്താവേ നിൻ സന്നിധിയിൽ"
        ],
        "linesRomanized": [
          "Karthave nin sannithiyil",
          "Njangalitha vannidunnu",
          "Aaradhanayode sthuthiyode",
          "Karthave nin sannithiyil"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "നിൻ കൃപയാൽ ഞങ്ങളെ",
          "കാത്തു രക്ഷിച്ചവനേ",
          "നിത്യ സ്നേഹത്താൽ",
          "ഞങ്ങളെ നടത്തുന്നവനേ"
        ],
        "linesRomanized": [
          "Nin krupayaal njangale",
          "Kaathu rakshichavane",
          "Nithya snehathaal",
          "Njangale nadathunnavane"
        ]
      }
    ]
  },
