  "story": "This powerful hymn celebrates the transforming grace of God. A favorite in revival meetings and regular worship services alike, it reminds believers that salvation comes not through works but through the unmerited grace of God. The repetitive refrain drives home the centrality of grace in the Christian life.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "കൃപയേ കൃപയേ",
          "കൃപ മാത്രം കൃപയേ",
          "എന്നെ രക്ഷിച്ചതു കൃപയേ"
        ],
        "linesRomanized": [
          "Krupaye krupaye",
          "Krupa maathram krupaye",
          "Enne rakshichathum krupaye"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "പാപത്തിൽ മുഴുകിയ എന്നെ",
          "കൃപയാൽ തേടി വന്നു",
          "ക്രൂശിൽ രക്തം ചിന്തി",
          "എന്നെ മുക്തനാക്കി"
        ],
        "linesRomanized": [
          "Paapathil muzhukiya enne",
          "Krupayaal thedi vannu",
          "Krooshil raktham chinthi",
          "Enne mukthanakki"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "യോഗ്യതയില്ലാത എന്നെ",
          "യോഗ്യനാക്കിയതു കൃപ",
          "നിത്യജീവൻ നൽകിയതു",
          "കൃപ മാത്രം കൃപയേ"
        ],
        "linesRomanized": [
          "Yogyathayillaatha enne",
          "Yogyanakkiyathum krupa",
          "Nithyajeevan nalkiyathum",
          "Krupa maathram krupaye"
        ]
      }
    ]
