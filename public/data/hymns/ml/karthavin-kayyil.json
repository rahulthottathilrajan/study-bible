    "grace"
  ],
  "scriptureRefs": [
    {
      "ref": "Isaiah 49:16",
      "note": "I have graven thee upon the palms of my hands"
    },
    {
      "ref": "John 10:28",
      "note": "Neither shall any man pluck them out of my hand"
    }
  ],
  "story": "A keerthanam of deep assurance that reminds believers they are held securely in God's hands. This traditional hymn draws from the tender image in Isaiah of God engraving His children on the palms of His hands. It has brought immeasurable comfort during funerals and times of loss in Kerala Christian communities.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "കർത്താവിൻ കൈയ്യിൽ ഞാൻ",
          "സുരക്ഷിതൻ എന്നേക്കും",
          "ആരും പിടിച്ചു പറിക്കുകയില്ല",
          "എന്നെ അവൻ കൈയ്യിൽ നിന്ന്"
        ],
        "linesRomanized": [
          "Karthavin kayyil njaan",
          "Surakshithan ennekkum",
          "Aarum pidichu parikkukayilla",
          "Enne avan kayyil ninnu"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ഉള്ളങ്കൈയ്യിൽ കൊത്തിവച്ചു",
          "എൻ നാമം അവൻ",
          "മറക്കുകയില്ല ഒരുനാളും",
          "എന്നെ അവൻ സ്നേഹിക്കും"
        ],
        "linesRomanized": [
          "Ullankayyil kothivachu",
          "En naamam avan",
          "Marakkukayilla orunaalum",
          "Enne avan snehikkum"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "കൊടുങ്കാറ്റ് വന്നാലും",
          "വെള്ളപ്പൊക്കം വന്നാലും",
          "കർത്താവിൻ കൈ എന്നെ താങ്ങും",
          "ഞാൻ ഭയപ്പെടുകയില്ല"
        ],
        "linesRomanized": [
          "Kodunkaattu vannaalum",
          "Vellapppokkam vannaalum",
          "Karthavin kai enne thaangum",
          "Njaan bhayappedukayilla"
        ]
      }
    ]
  },
