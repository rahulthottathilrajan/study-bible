  "story": "A profound declaration keerthanam based on Christ's 'I Am' statements in the Gospel of John. This hymn meditates on Jesus as the Way, the Truth, and the Life, inviting believers into a deeper understanding of who Christ is. It has been a cherished part of Kerala Sunday worship for generations.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "വഴിയും സത്യവും ജീവനും",
          "നീയല്ലോ യേശുവേ",
          "നിന്നിലൂടെയല്ലാതെ",
          "പിതാവിൻ അടുക്കൽ ആർക്കും വരാൻ കഴിയില്ല"
        ],
        "linesRomanized": [
          "Vazhiyum sathyavum jeevanum",
          "Neeyallo Yeshuve",
          "Ninniloodeyallathe",
          "Pithaavin adukkal aarkum varaan kazhiyilla"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ഞാനാണ് നല്ല ഇടയൻ",
          "ആടുകൾക്കായ് ജീവൻ കൊടുക്കും",
          "ഞാനാണ് ഉയിർപ്പും ജീവനും",
          "വിശ്വസിക്കുന്നവൻ ജീവിക്കും"
        ],
        "linesRomanized": [
          "Njaanaanu nalla idayan",
          "Aadukalkkaay jeevan kodukkum",
          "Njaanaanu uyirppum jeevanum",
          "Vishvasikkunavan jeevikkum"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ഞാനാണ് ലോകത്തിൻ വെളിച്ചം",
          "എന്നെ പിന്തുടരുന്നവൻ",
          "ഇരുളിൽ നടക്കുകയില്ല",
          "ജീവന്റെ വെളിച്ചം ഉണ്ടാകും"
        ],
        "linesRomanized": [
          "Njaanaanu lokathinte velicham",
          "Enne pinthudarunnavan",
          "Irulil nadakkukayilla",
          "Jeevante velicham undaakum"
        ]
      }
    ]
  },
