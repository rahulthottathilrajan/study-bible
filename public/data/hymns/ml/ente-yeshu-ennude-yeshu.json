  "story": "A deeply personal devotional hymn expressing intimate love and devotion to Jesus Christ. This traditional keerthanam captures the heart of Kerala Christian spirituality—a personal, loving relationship with the Saviour. Sung in both worship services and personal devotion times.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "എന്റെ യേശു എന്നുടെ യേശു",
          "എന്റെ സ്നേഹം എന്നുടെ രക്ഷ",
          "എൻ ജീവനത്തിൻ സർവ്വം",
          "എന്റെ യേശു മാത്രം"
        ],
        "linesRomanized": [
          "Ente Yeshu ennude Yeshu",
          "Ente sneham ennude raksha",
          "En jeevanthinte sarvvam",
          "Ente Yeshu maathram"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ക്രൂശിൽ എനിക്കായി മരിച്ചു",
          "മൂന്നാം നാളിൽ ഉയിർത്തു",
          "പാപത്തിൽ നിന്നു മോചിച്ചു",
          "നിത്യജീവൻ നൽകുന്നു"
        ],
        "linesRomanized": [
          "Krooshil enikkayi marichu",
          "Moonnaam naalil uyirthu",
          "Paapathil ninnu mochichu",
          "Nithyajeevan nalkunnu"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "എന്റെ നല്ല ഇടയനായി",
          "എന്റെ സ്നേഹിതനായി",
          "എൻ ഹൃദയത്തിൽ വാഴുന്നു",
          "എന്റെ യേശു സ്നേഹം"
        ],
        "linesRomanized": [
          "Ente nalla idayanayi",
          "Ente snehithanayi",
          "En hrudayathil vaazhunnu",
          "Ente Yeshu sneham"
        ]
      }
    ]
  },
