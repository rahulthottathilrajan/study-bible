  "story": "An exuberant praise keerthanam that fills Kerala churches with declarations of God's glory. This congregational hymn draws from the heavenly worship scenes in Revelation, calling believers to ascribe all glory to the Almighty. Its stirring melody lifts voices in united worship across denominations.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "മഹത്വം മഹത്വം ദൈവത്തിന്",
          "ഘനം ഘനം പ്രഭുവിന്",
          "സ്തുതി സ്തുതി യേശുവിന്",
          "എന്നേക്കും മഹത്വം"
        ],
        "linesRomanized": [
          "Mahathwam mahathwam Daivathin",
          "Ghanam ghanam Prabhuvin",
          "Sthuthi sthuthi Yeshuvin",
          "Ennekkum mahathwam"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ആകാശവും ഭൂമിയും",
          "ഉണ്ടാക്കിയ ദൈവത്തിന്",
          "സകലവും സൃഷ്ടിച്ച ദൈവത്തിന്",
          "മഹത്വം മഹത്വം"
        ],
        "linesRomanized": [
          "Aakaashavum bhoomiyum",
          "Undaakkiya Daivathin",
          "Sakalavum srushtticha Daivathin",
          "Mahathwam mahathwam"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ദൂതന്മാർ ആരാധിക്കും",
          "സെരാഫിമുകൾ സ്തുതിക്കും",
          "സർവ്വ സൃഷ്ടിയും പാടും",
          "മഹത്വം മഹത്വം"
        ],
        "linesRomanized": [
          "Doothanmaar aaradhikkum",
          "Seraaphimukal sthuthikkum",
          "Sarvva srushtiyum paadum",
          "Mahathwam mahathwam"
        ]
      }
    ]
