  "story": "A hymn of patient trust in God's timing, drawn from Isaiah 40. This keerthanam encourages believers to wait upon the Lord with renewed hope. It has been a source of strength in Kerala prayer meetings, especially for those going through seasons of waiting and uncertainty.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "കാത്തിരിക്കും ഞാൻ കർത്താവിൽ",
          "ബലം പുതുക്കും കർത്താവ്",
          "കഴുകനെ പോലെ ഉയരും",
          "ക്ഷീണിക്കുകയില്ല തളരുകയില്ല"
        ],
        "linesRomanized": [
          "Kaathirikkum njaan Karthaavil",
          "Balam puthikkum Karthaav",
          "Kazhukane pole uyarum",
          "Ksheenikukayilla thalarukayilla"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ഓടും ക്ഷീണിക്കുകയില്ല",
          "നടക്കും തളരുകയില്ല",
          "കർത്താവിൽ കാത്തിരിക്കുന്നവർ",
          "ബലം പ്രാപിക്കും"
        ],
        "linesRomanized": [
          "Odum ksheenikukayilla",
          "Nadakkum thalarukayilla",
          "Karthaavil kaathirikkunavar",
          "Balam praapikkum"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ബാലന്മാർ ക്ഷീണിച്ചാലും",
          "യൗവ്വനക്കാർ ഇടറിയാലും",
          "കർത്താവിൽ ആശ്രയിക്കുന്നവർ",
          "ഒരുനാളും വീഴുകയില്ല"
        ],
        "linesRomanized": [
          "Baalanmaar ksheenichalum",
          "Yauvanakkaar idariyaalum",
          "Karthaavil aashrayikkunavar",
          "Orunaalum veezhukayilla"
        ]
      }
    ]
  },
