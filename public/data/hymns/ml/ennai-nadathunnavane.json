{
  "id": "ennai-nadathunnavane",
  "lang": "ml",
  "title": "എന്നെ നടത്തുന്നവനേ",
  "titleRomanized": "Enne Nadathunnavane",
  "author": "Traditional",
  "composer": "Traditional Kerala melody",
  "year": null,
  "categories": [
    "comfort",
    "worship"
  ],
  "scriptureRefs": [
    {
      "ref": "Psalm 23:1-2",
      "note": "The LORD is my shepherd; I shall not want. He maketh me to lie down in green pastures"
    },
    {
      "ref": "Isaiah 40:11",
      "note": "He shall feed his flock like a shepherd"
    }
  ],
  "story": "A tender shepherd-psalm keerthanam rooted in Psalm 23, cherished in Kerala home prayer meetings. This hymn paints a picture of God's tender care and guidance through life's valleys and mountains. Its gentle melody has comforted countless believers through times of uncertainty and grief.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "എന്നെ നടത്തുന്നവനേ",
          "പച്ചപ്പുൽപ്പുറത്ത് കിടത്തുന്നവനേ",
          "ശാന്തമാം ജലത്തിൻ കരയിൽ",
          "എന്നെ ചേർക്കുന്നവനേ"
        ],
        "linesRomanized": [
          "Enne nadathunnavane",
          "Pachappulppurathu kidathunnavane",
          "Shaanthamaam jalathin karayil",
          "Enne cherkkunnavane"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "മരണനിഴലിൻ താഴ്‌വരയിലും",
          "ഞാൻ ഭയപ്പെടുകയില്ല",
          "നീ എന്നോടുകൂടെ ഉണ്ട്",
          "നിൻ വടിയും കോലും എന്നെ ആശ്വസിപ്പിക്കും"
        ],
        "linesRomanized": [
          "Marananizhalin thaazhvarayilum",
          "Njaan bhayappedukayilla",
          "Nee ennodukkoode undu",
          "Nin vadiyum kolum enne aashvasippikkum"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "നന്മയും കരുണയും",
          "ജീവിതകാലമെല്ലാം",
          "എന്നെ പിന്തുടരും",
          "കർത്താവിൻ ഭവനത്തിൽ വസിക്കും"
        ],
        "linesRomanized": [
          "Nanmayum karunayum",
          "Jeevithakaalamellaam",
          "Enne pinthudarum",
          "Karthaavin bhavanathil vasikkum"
        ]
      }
    ]
  },
