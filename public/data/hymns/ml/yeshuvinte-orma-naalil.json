  "story": "A solemn and sacred hymn sung during the breaking of bread in Kerala churches. This traditional communion keerthanam is heard across Marthoma, CSI, and Brethren assemblies during the Lord's Supper. Its reverent melody invites believers to remember Christ's sacrifice and partake in grateful remembrance.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "യേശുവിന്റെ ഓർമ്മ നാളിൽ",
          "കൂടി വന്നു നമ്മൾ ഇന്ന്",
          "അപ്പം നുറുക്കി പങ്കിടാം",
          "കർത്താവിൻ മരണം ഓർക്കാം"
        ],
        "linesRomanized": [
          "Yeshuvinte orma naalil",
          "Koodi vannu nammal innu",
          "Appam nurukki pankidaam",
          "Karthaavin maranam orkkaam"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ക്രൂശിൽ ചൊരിഞ്ഞ രക്തത്താൽ",
          "പാപം കഴുകി ശുദ്ധമാക്കി",
          "നിത്യജീവൻ നൽകിയവൻ",
          "അവനെ ഓർത്തിടാം നമുക്ക്"
        ],
        "linesRomanized": [
          "Krooshil chorinja rakthatthaal",
          "Paapam kazhuki shuddhimaakki",
          "Nithyajeevan nalkiyavan",
          "Avane orthidaam namukku"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "വീണ്ടും വരും നാൾ വരെ",
          "ഈ ഓർമ്മ കാത്തിടാം",
          "നന്ദിയോടെ പങ്കിടാം",
          "കർത്താവിൻ തിരുശരീരം"
        ],
        "linesRomanized": [
          "Veendum varum naal vare",
          "Ee orma kaathidaam",
          "Nandiyode pankidaam",
          "Karthaavin thirushareerum"
        ]
      }
    ]
  },
