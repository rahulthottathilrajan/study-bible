  "scriptureRefs": [
    {
      "ref": "1 John 4:19",
      "note": "We love him, because he first loved us"
    },
    {
      "ref": "Psalm 18:1",
      "note": "I will love thee, O LORD, my strength"
    }
  ],
  "story": "An intimate devotional keerthanam expressing the believer's love for Christ in response to His first love. This tender hymn is a favorite during evening prayer meetings and personal devotion times in Kerala homes. Its heartfelt melody captures the depth of a soul surrendered in love to its Saviour.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "സ്നേഹിക്കുന്നു ഞാൻ നിന്നെ യേശുവേ",
          "നീ ആദ്യം സ്നേഹിച്ചതുകൊണ്ട്",
          "എൻ ജീവൻ നിനക്കായ് അർപ്പിക്കുന്നു",
          "എൻ സർവ്വസ്വം നിനക്കായ്"
        ],
        "linesRomanized": [
          "Snehikkunnu njaan ninne Yeshuve",
          "Nee aadyam snehichathukond",
          "En jeevan ninakkaay arppikkunnu",
          "En sarvvasvam ninakkaay"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ക്രൂശിൽ നിൻ സ്നേഹം കണ്ടു ഞാൻ",
          "എന്നെ മറന്ന് നീ മരിച്ചു",
          "ആ സ്നേഹത്തിന് പകരം",
          "എൻ ഹൃദയം നിനക്കായ്"
        ],
        "linesRomanized": [
          "Krooshil nin sneham kandu njaan",
          "Enne marannu nee marichu",
          "Aa snehathinu pakaram",
          "En hrudayam ninakkaay"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ലോകം മുഴുവൻ തന്നാലും",
          "നിൻ സ്നേഹത്തിന് തുല്യമല്ല",
          "സ്നേഹിക്കുന്നു ഞാൻ നിന്നെ",
          "എന്നേക്കും സ്നേഹിക്കും"
        ],
        "linesRomanized": [
          "Lokam muzhuvan thannaalum",
          "Nin snehathinu thulyamalla",
          "Snehikkunnu njaan ninne",
          "Ennekkum snehikkum"
        ]
      }
    ]
  },
