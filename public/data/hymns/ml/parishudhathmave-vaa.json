  "story": "A beloved invocation hymn sung across Pentecostal and charismatic churches in Kerala. This traditional keerthanam is often the opening prayer of revival meetings and tarrying services, calling upon the Holy Spirit to descend upon the gathered believers. Its simple, repetitive structure allows the entire congregation to join in fervent worship.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "പരിശുദ്ധാത്മാവേ വാ",
          "ഞങ്ങളിൽ വന്നു നിറയുക",
          "അഗ്നിയായ് ഇറങ്ങിവാ",
          "ശക്തിയാൽ നിറയ്ക്കുക"
        ],
        "linesRomanized": [
          "Parishudhathmave vaa",
          "Njangalil vannu nirayuka",
          "Agniyaay irangivaa",
          "Shakthiyaal niraykkuka"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "പെന്തക്കോസ്തു നാളിൽ പോലെ",
          "അഗ്നി നാവുകൾ പോലെ",
          "ഇറങ്ങി വരേണമേ",
          "പരിശുദ്ധാത്മാവേ വാ"
        ],
        "linesRomanized": [
          "Penthakkosthu naalil pole",
          "Agni naavukal pole",
          "Irangi varename",
          "Parishudhathmave vaa"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "ദാനങ്ങൾ നൽകേണമേ",
          "വരങ്ങൾ പകരേണമേ",
          "ശക്തിയാൽ അണിയിക്കുക",
          "പരിശുദ്ധാത്മാവേ വാ"
        ],
        "linesRomanized": [
          "Daanangal nalkename",
          "Varangal pakarename",
          "Shakthiyaal aniyikkuka",
          "Parishudhathmave vaa"
        ]
      }
    ]
