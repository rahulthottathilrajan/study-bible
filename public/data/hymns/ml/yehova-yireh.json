  "story": "A keerthanam celebrating the names of God and His provision. Drawing from Abraham's encounter on Mount Moriah, this traditional hymn declares that God sees and provides for every need. It is a beloved testimony hymn in Kerala churches, often sung when believers share stories of God's faithfulness.",
  "lyrics": {
    "structure": [
      {
        "type": "chorus",
        "lines": [
          "യഹോവ യിരെ കരുതും ദൈവം",
          "യഹോവ ശാലോം സമാധാനം",
          "യഹോവ നിസ്സി ജയം തരും",
          "യഹോവ എൻ ദൈവം"
        ],
        "linesRomanized": [
          "Yehova Yireh karuthum Daivam",
          "Yehova Shaalom samaadhaanam",
          "Yehova Nissi jayam tharum",
          "Yehova en Daivam"
        ]
      },
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ആവശ്യങ്ങൾ എല്ലാം അറിയുന്നവൻ",
          "തക്ക സമയത്ത് നൽകുന്നവൻ",
          "മഹത്വത്തിൻ ധനത്തിൽ നിന്ന്",
          "സകലവും നൽകും ദൈവം"
        ],
        "linesRomanized": [
          "Aavashyangal ellaam ariyunnavan",
          "Thakka samayath nalkunnavan",
          "Mahathwathin dhanathil ninnu",
          "Sakalavum nalkum Daivam"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "അബ്രാഹാമിൻ ദൈവം",
          "യിസ്ഹാക്കിൻ ദൈവം",
          "യാക്കോബിൻ ദൈവം",
          "ഇന്നും ജീവിക്കുന്ന ദൈവം"
        ],
        "linesRomanized": [
          "Abraahaamin Daivam",
          "Yishaakkin Daivam",
          "Yaakkobin Daivam",
          "Innum jeevikkunna Daivam"
        ]
      }
    ]
