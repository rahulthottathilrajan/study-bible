  "story": "An ancient devotional keerthanam from the Syrian Christian tradition of Kerala, this hymn meditates on the meaning of the cross. Sung during Lenten services and Good Friday observances, it invites believers to kneel at the foot of the cross and contemplate Christ's sacrificial love. The melody carries the weight of centuries of Kerala Christian devotion.",
  "lyrics": {
    "structure": [
      {
        "type": "verse",
        "number": 1,
        "lines": [
          "ക്രൂശിന്റെ അടിയിൽ നിന്നു",
          "കണ്ണുനീർ വാർത്തിടുന്നു",
          "എനിക്കായ് മരിച്ച നാഥാ",
          "നിൻ സ്നേഹം എത്ര വലുത്"
        ],
        "linesRomanized": [
          "Krooshinte adiyil ninnu",
          "Kannuneer vaarithidunnu",
          "Enikkaayi maricha Naathaa",
          "Nin sneham ethra valuth"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "lines": [
          "മുൾമുടി ചൂടിയവനെ",
          "ആണിപ്പഴുതിൽ തൂങ്ങിയവനെ",
          "എന്റെ പാപം ചുമന്നവനെ",
          "നന്ദി നന്ദി യേശുവേ"
        ],
        "linesRomanized": [
          "Mulmudi choodiyavane",
          "Aanipppazhuthil thoongiyavane",
          "Ente paapam chumannavane",
          "Nandi nandi Yeshuve"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "lines": [
          "ക്രൂശിൽ ഞാൻ അഭയം തേടും",
          "ക്രൂശിൽ ഞാൻ ശരണം നേടും",
          "ക്രൂശല്ലാതെ മറ്റൊന്നുമില്ല",
          "ക്രൂശാണ് എന്റെ മഹത്വം"
        ],
        "linesRomanized": [
          "Krooshil njaan abhayam thedum",
          "Krooshil njaan sharanam nedum",
          "Krooshallathe mattonnumilla",
          "Krooshaanu ente mahatwam"
        ]
      }
    ]
  },
